MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "3 \u04D8\u043A\u0435\u0438\u0306\u0434\u0456\u04A3 \u0430\u0493\u0430\u0448\u0442\u0430\u043D
    \u041C\u043E\u0434\u0443\u043B\u044C1 \u043E\u0437\u0432\u0443\u0447\u043A\u0430"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0412\u044B\u0440\u0435\u0437\u0430\u043D\u043D\u044B\u0435 \u043E\u0442\u0446\u043E\u043C
      \u0438\u0437 \u0434\u0435\u0440\u0435\u0432\u0430 \u0430\u0440\u0445\u0430\u0440\u044B,
      \u0432\u043E\u043B\u043A\u0438, \u0434\u0438\u043A\u0438\u0435 \u0433\u0443\u0441\u0438
      \u0438 \u0443\u0442\u043A\u0438 \u0431\u044B\u043B\u0438 \u0447\u0430\u0441\u0442\u044C\u044E
      \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u043E\u0433\u043E \u043C\u0438\u0440\u0430
      \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0433\u043E \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C\u0430."
    kazakhText: "\u04D8\u043A\u0435\u0439\u0434\u0456\u04A3 \u0430\u0493\u0430\u0448\u0442\u0430\u043D
      \u043E\u0439\u044B\u043F \u0436\u0430\u0441\u0430\u0493\u0430\u043D \u2013
      \u0430\u0440\u049B\u0430\u0440, \u049B\u0430\u0441\u049B\u044B\u0440, \u049B\u0430\u0437-\u04AF\u0439\u0440\u0435\u043A\u0442\u0435\u0440\u0456
      \u0431\u0430\u043B\u0430 \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C\u043D\u0456\u04A3 
      \u0431\u0430\u049B\u044B\u0442\u0442\u044B \u0448\u0430\u0493\u044B \u0435\u0434\u0456."
    englishText: "The wooden argali sheep, wolves, wild geese, and ducks carved by
      his father became part of young Shakarim\u2019s happiest memories."
    duration: 7
  - russianText: "\u041E\u0431 \u044D\u0442\u043E\u043C \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u044E\u0442
      \u0438 \u0437\u0430\u043F\u0438\u0441\u0438 \u0441\u0430\u043C\u043E\u0433\u043E
      \u0445\u0430\u0434\u0436\u0438."
    kazakhText: "\u0411\u04B1\u0493\u0430\u043D \u049B\u0430\u0436\u044B\u043D\u044B\u04A3
      \u043A\u04E9\u04A3\u0456\u043B \u0436\u0430\u0437\u0431\u0430\u043B\u0430\u0440\u044B
      \u0434\u04D9\u043B\u0435\u043B."
    englishText: The notes left by the hajji himself bear witness to this.
    duration: 3
  - russianText: "\u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
      \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u043E\u0441\u043E\u0431\u043E\u0433\u043E
      \u0441\u043A\u043B\u0430\u0434\u0430 \u2014 \u0442\u0435\u043C, \u043A\u0442\u043E
      \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u043B \u0434\u0435\u0442\u0441\u043A\u043E\u0435
      \u0441\u0435\u0440\u0434\u0446\u0435 \u0432 \u0441\u043E\u0441\u0443\u0434
      \u043C\u0438\u043B\u043E\u0441\u0435\u0440\u0434\u0438\u044F."
    kazakhText: "\u0428\u04D9\u043A\u04D9\u0440\u0456\u043C  - \u0431\u0430\u043B\u0430
      \u0436\u04AF\u0440\u0435\u0433\u0456\u043D \u043C\u0435\u0439\u0456\u0440\u0456\u043C
      \u049B\u04B1\u0442\u044B\u0441\u044B\u043D\u0430 \u0430\u0439\u043D\u0430\u043B\u0434\u044B\u0440\u0493\u0430\u043D,
      \u0442\u0443\u043C\u044B\u0441\u044B\u043D\u0430\u043D \u0431\u04E9\u043B\u0435\u043A
      \u0436\u0430\u043D \u0435\u0434\u0456."
    englishText: "From childhood, Shakarim was unlike others \u2014 a soul born to
      turn the human heart into a vessel of mercy."
    duration: 6
  - russianText: "\u0415\u0433\u043E \u043C\u0430\u0442\u044C \u0422\u04E9\u043B\u0435\u0431\u0438\u043A\u0435
      \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E \u0432\u043B\u0430\u0434\u0435\u043B\u0430
      \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u043C \u0438 \u0442\u0443\u0440\u0435\u0446\u043A\u0438\u043C
      \u044F\u0437\u044B\u043A\u0430\u043C\u0438, \u0438\u0441\u043A\u0443\u0441\u043D\u043E
      \u0448\u0438\u043B\u0430 \u043E\u0434\u0435\u0436\u0434\u0443, \u0441\u043B\u0430\u0432\u0438\u043B\u0430\u0441\u044C
      \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u043E\u043C \u0440\u0443\u043A\u043E\u0434\u0435\u043B\u044C\u043D\u0438\u0446\u044B,
      \u0443\u043C\u0435\u043B\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
      \u0441 \u043C\u0435\u0442\u0430\u043B\u043B\u043E\u043C \u0438 \u043A\u043E\u0432\u0430\u0442\u044C
      \u0436\u0435\u043B\u0435\u0437\u043E."
    kazakhText: "\u0428\u04D9\u043A\u04D9\u0440\u0456\u043C\u043D\u0456\u04A3 \u0430\u043D\u0430\u0441\u044B
      \u0422\u04E9\u043B\u0435\u0431\u0438\u043A\u0435 \u0430\u0440\u0430\u0431,
      \u0442\u04AF\u0440\u0456\u043A \u0442\u0456\u043B\u0434\u0435\u0440\u0456\u043D
      \u0435\u0440\u043A\u0456\u043D \u043C\u0435\u04A3\u0433\u0435\u0440\u0433\u0435\u043D,
      \u043A\u0438\u0456\u043C \u043F\u0456\u0448\u0456\u043F,  \u0448\u0435\u0431\u0435\u0440
      \u0430\u0442\u0430\u043D\u0493\u0430\u043D,  \u04B1\u0441\u0442\u0430\u043B\u044B\u049B
      \u0436\u0430\u0441\u0430\u043F, \u0442\u0435\u043C\u0456\u0440 \u0431\u04B1\u0439\u044B\u043C
      \u0441\u043E\u049B\u049B\u0430\u043D."
    englishText: His mother, Tolebike, spoke Arabic and Turkish fluently, was skilled
      in tailoring, renowned for her craftsmanship, and could even forge iron with
      her own hands.
    duration: 12
  - russianText: "\u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u043E\u043D\u0430
      \u0449\u0435\u0434\u0440\u043E \u043E\u0434\u0430\u0440\u0438\u0432\u0430\u043B\u0430
      \u0441\u044B\u043D\u0430 \u043C\u0430\u0442\u0435\u0440\u0438\u043D\u0441\u043A\u043E\u0439
      \u043B\u044E\u0431\u043E\u0432\u044C\u044E \u0438 \u0442\u0435\u043F\u043B\u043E\u043C."
    kazakhText: "\u0411\u0430\u043B\u0430\u0441\u044B\u043D\u0430 \u0430\u043D\u0430\u043B\u044B\u049B
      \u043C\u0430\u0445\u0430\u0431\u0431\u0430\u0442\u044B\u043D \u0430\u044F\u043C\u0430\u0493\u0430\u043D
      \u0456\u0437\u0433\u0456 \u0436\u0430\u043D \u0434\u0435\u0441\u0435\u0434\u0456."
    englishText: People remembered her as a woman who never spared her son the warmth
      of maternal love.
    duration: 4
  - russianText: "\u041D\u043E \u0441\u0443\u0434\u044C\u0431\u0430, \u0441\u043B\u043E\u0432\u043D\u043E
      \u0441\u0442\u0440\u043E\u043A\u0438, \u043D\u0430\u0447\u0435\u0440\u0442\u0430\u043D\u043D\u044B\u0435
      \u043D\u0430 \u0421\u043A\u0440\u0438\u0436\u0430\u043B\u0438 \u043C\u0438\u0440\u0430,
      \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0440\u0430\u043D\u043E \u043F\u043E\u0434\u0432\u0435\u0440\u0433\u043B\u0430
      \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0433\u043E \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C\u0430
      \u0441\u0432\u043E\u0438\u043C \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F\u043C\u2026"
    kazakhText: "\u0410\u043B\u0430\u0439\u0434\u0430, \u041B\u0430\u0443\u0445\u044B
      \u0436\u0430\u0437\u0431\u0430\u0441\u044B  \u0431\u0430\u043B\u0430 \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C\u0434\u0456
      \u04E9\u0437 \u0441\u044B\u043D\u0430\u0493\u044B\u043D\u0430 \u0435\u0440\u0442\u0435
      \u0430\u043B\u0434\u044B..."
    englishText: "Yet fate \u2014 as though written long before upon the Eternal
      Tablet \u2014 drew little Shakarim into its trials far too early\u2026"
    duration: 6
