MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "\u041D\u0430\u0447\u0430\u043B\u043E \u0428\u044B\u043D\u0433\u044B\u0441\u0442\u0430\u0443
    \u041C\u043E\u0434\u0443\u043B\u044C 1"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\xAB\u0428\u044B\u04A3\u0493\u044B\u0441\u0442\u0430\u0443\u2026
      \u0417\u0435\u043C\u043B\u044F, \u0433\u0434\u0435 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
      \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456\u04B1\u043B\u044B
      \u2013 \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u044C, \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0432\u0448\u0438\u0439
      \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0438\u0439 \u0440\u0430\u0437\u0443\u043C
      \u0432 \u043C\u043E\u043B\u0438\u0442\u0432\u0435\u043D\u043D\u0443\u044E \u043F\u0435\u0441\u043D\u044C
      \u0434\u0443\u0445\u0430\u2026"
    kazakhText: "\"\u0428\u044B\u04A3\u0493\u044B\u0441\u0442\u0430\u0443... \u0410\u049B\u044B\u043B-\u043E\u0439\u0434\u044B
      \u0493\u0438\u0431\u0430\u0434\u0430\u0442 \u0436\u044B\u0440\u044B\u043D\u0430
      \u0430\u0439\u043D\u0430\u043B\u0434\u044B\u0440\u0493\u0430\u043D \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C
      \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456\u04B1\u043B\u044B
      \u0434\u04AF\u043D\u0438\u0435\u0433\u0435 \u043A\u0435\u043B\u0433\u0435\u043D
      \u0436\u0435\u0440...."
    englishText: "\u201CShyngystau\u2026 The sacred land where Shakarim Kudaiberdiuly
      was born \u2014 the sage who transformed human thought into a hymn of spiritual
      devotion\u2026"
    duration: 9
  - russianText: "\u0425\u043E\u0442\u044F \u043F\u0440\u0438 \u0430\u0437\u0430\u043D\u0435
      \u0435\u043C\u0443 \u0431\u044B\u043B\u043E \u0434\u0430\u043D\u043E \u0438\u043C\u044F
      \u0428\u0430\u04BB-\u041A\u04D9\u0440\u0456\u043C, \u0432 \u043D\u0430\u0440\u043E\u0434\u0435
      \u043E\u043D \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C\u043E\u043C\u2026"
    kazakhText: "\u0410\u0437\u0430\u043D \u0448\u0430\u049B\u044B\u0440\u044B\u043F
      \u049B\u043E\u0439\u0493\u0430\u043D \u0435\u0441\u0456\u043C\u0456 \u0428\u0430\u04BB-\u043A\u04D9\u0440\u0456\u043C
      \u0431\u043E\u043B\u0441\u0430 \u0434\u0430, \u0435\u043B \u0456\u0448\u0456\u043D\u0434\u0435
      \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C..."
    englishText: "Though the name given to him during the azan was Shah-Karim, among
      the people he became known simply as Shakarim\u2026"
    duration: 6
  - russianText: "\u0412 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0435 \u0441
      \u043F\u0435\u0440\u0441\u0438\u0434\u0441\u043A\u043E\u0433\u043E \xAB\u0428\u0430\u04BB\xBB
      \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442 \xAB\u0432\u044B\u0441\u043E\u043A\u043E\u0447\u0442\u0438\u043C\u044B\u0439\xBB,
      \xAB\u0432\u0435\u043B\u0438\u043A\u0438\u0439\xBB,"
    kazakhText: "\u041F\u0430\u0440\u0441\u044B \u0442\u0456\u043B\u0456\u043D\u0435\u043D
      \u0430\u0443\u0434\u0430\u0440\u0493\u0430\u043D\u0434\u0430 \xAB\u0428\u0430\u04BB\xBB 
      - \u0430\u0441\u0430 \u049B\u0430\u0434\u0456\u0440\u043B\u0456, \u049B\u04B1\u0440\u043C\u0435\u0442\u0442\u0456,"
    englishText: "In Persian, Shah means \u201Cmost revered,\u201D \u201Cnoble,\u201D"
    duration: 5
  - russianText: "\u0430 \xAB\u041A\u04D9\u0440\u0456\u043C\xBB \u2014 \xAB\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u044B\u0439\xBB,
      \xAB\u0431\u0435\u0437\u0433\u0440\u0430\u043D\u0438\u0447\u043D\u044B\u0439\xBB,
      \xAB\u043D\u0435\u0438\u0441\u0447\u0435\u0440\u043F\u0430\u0435\u043C\u044B\u0439\xBB,
      \u043F\u043E\u0434\u043E\u0431\u043D\u043E \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u043C\u0443
      \u041A\u043E\u0440\u0430\u043D\u0443 \u2013 \u041A\u043D\u0438\u0433\u0435
      \u041A\u0430\u0440\u0438\u043C."
    kazakhText: "\xAB\u041A\u04D9\u0440\u0456\u043C\xBB  \u2013  \u049B\u0430\u0441\u0438\u0435\u0442\u0442\u0456
      \u049A\u04B1\u0440\u0430\u043D \u041A\u04D9\u0440\u0456\u043C \u043A\u0456\u0442\u0430\u0431\u044B\u043D\u0434\u0430\u0439
      \xAB\u041A\u0435\u04A3\xBB, \u0442\u04AF\u043F\u0441\u0456\u0437, \u0448\u0435\u043A\u0441\u0456\u0437
      \u0434\u0435\u0433\u0435\u043D \u043C\u0430\u0493\u044B\u043D\u0430\u043D\u044B
      \u0431\u0456\u043B\u0434\u0456\u0440\u0435\u0434\u0456."
    englishText: "while Karim signifies \u201Csacred,\u201D \u201Cboundless,\u201D
      \u201Cimmeasurable,\u201D much like the Holy Quran itself \u2014 eternal and
      infinite in meaning."
    duration: 8
  - russianText: "\u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u2014 \u0441\u044B\u043D
      \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456, \u0440\u043E\u0436\u0434\u0451\u043D\u043D\u043E\u0433\u043E
      \u043E\u0442 \u0441\u0442\u0430\u0440\u0448\u0435\u0439 \u0441\u0443\u043F\u0440\u0443\u0433\u0438
      \u049A\u04B1\u043D\u0430\u043D\u0431\u0430\u044F \u2014 \u041A\u04AF\u043D\u043A\u0435."
    kazakhText: "\u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u2013 \u049A\u04B1\u043D\u0430\u043D\u0431\u0430\u0439\u0434\u044B\u04A3
      \u041A\u04AF\u04A3\u043A\u0435 \u0431\u04D9\u0439\u0431\u0456\u0448\u0435\u0441\u0456\u043D\u0435\u043D
      \u0442\u0443\u0493\u0430\u043D \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456\u043D\u0456\u04A3
      \u0431\u0430\u043B\u0430\u0441\u044B."
    englishText: "Shakarim was the son of Kudaiberdi, born to Kunanbay\u2019s senior
      wife, Kunke."
    duration: 6
  - russianText: "\u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456
      \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0431\u043B\u0430\u0433\u043E\u0440\u043E\u0434\u043D\u043E\u0433\u043E
      \u043D\u0440\u0430\u0432\u0430, \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u043D\u044B\u043C,
      \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0441\u0432\u0435\u0434\u0443\u0449\u0438\u043C
      \u0432 \u043D\u0430\u0443\u043A\u0435 \u0438 \u043F\u0440\u043E\u0441\u0432\u0435\u0449\u0435\u043D\u0438\u0438;
      \u043E\u043D \u043F\u043E\u043D\u0438\u043C\u0430\u043B \u044F\u0437\u044B\u043A
      \u043F\u0442\u0438\u0446 \u0438 \u0442\u0430\u0439\u043D\u044B\u0439 \u043F\u0443\u043B\u044C\u0441
      \u0437\u0435\u043C\u043B\u0438."
    kazakhText: "\xAB\u041C\u0456\u043D\u0435\u0437\u0434\u0456, \u0442\u04D9\u043B\u0456\u043C\u0434\u0456,
      \u043E\u049B\u0443-\u0493\u044B\u043B\u044B\u043C\u0493\u0430 \u0436\u0435\u0442\u0456\u043A
      \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456 \u0436\u0435\u0440\u0434\u0456\u04A3
      \u0442\u0456\u043D\u0456\u043D, \u049B\u04B1\u0441\u0442\u044B\u04A3 \u0442\u0456\u043B\u0456\u043D
      \u0431\u0456\u043B\u0433\u0435\u043D \u0441\u044B\u0440\u043B\u044B \u0436\u0430\u043D
      \u0431\u043E\u043B\u0493\u0430\u043D."
    englishText: They say Kudaiberdi was a man of dignity and wisdom, deeply educated
      and refined, one who understood the pulse of the earth and the language of
      birds.
    duration: 10
  - russianText: "\u041F\u043E\u0442\u043E\u043C\u0443 \u0438\u043C\u0435\u043D\u043D\u043E
      \u0435\u043C\u0443 \u0434\u043E\u0432\u0435\u0440\u044F\u043B\u0438 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
      \u043B\u0435\u0442\u043D\u0438\u043C\u0438 \u0436\u0430\u0439\u043B\u044F\u0443
      \u0438 \u0437\u0438\u043C\u043E\u0432\u043A\u0430\u043C\u0438."
    kazakhText: "\u0421\u043E\u043D\u0434\u044B\u049B\u0442\u0430\u043D \u0436\u0430\u0437
      \u0436\u0430\u0439\u043B\u0430\u0443, \u049B\u044B\u0441 \u049B\u043E\u043D\u044B\u0441\u0442\u044B
      \u0431\u0430\u0441\u049B\u0430\u0440\u0493\u0430\u043D."
    englishText: For this reason, he was entrusted with governing both the summer
      pastures and the winter settlements.
    duration: 4
  - russianText: "\u041E\u0441\u043E\u0431\u043E\u0435 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
      \u0443\u0434\u0435\u043B\u044F\u043B \u043E\u043D \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u044E
      \u0434\u0435\u0442\u0435\u0439\u2026"
    kazakhText: "\u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456 \u0431\u0430\u043B\u0430
      \u0442\u04D9\u0440\u0431\u0438\u0435\u0441\u0456\u043D\u0435 \u0435\u0440\u0435\u043A\u0448\u0435
      \u0437\u0435\u0440 \u0441\u0430\u043B\u0493\u0430\u043D \u0434\u0435\u0441\u0435\u0434\u0456....\r\n"
    englishText: "It is also said that he paid extraordinary attention to the upbringing
      of his children\u2026"
    duration: 4
