  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "2 \u04D8\u043A\u0435 \u043C\u0435\u043D \u041C\u043E\u0434\u0443\u043B\u044C1
    \u043E\u0437\u0432\u0443\u0447\u043A\u0430 (mp3cut.net)"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0414\u0435\u0442\u0441\u043A\u0438\u0439 \u0433\u043E\u043B\u043E\u0441:
      \u2014 \u041F\u043E\u0441\u043C\u043E\u0442\u0440\u0438\u0442\u0435, \u044F
      \u0442\u043E\u0436\u0435 \u0432\u044B\u0440\u0435\u0437\u0430\u043B \u0438\u0437
      \u0434\u0435\u0440\u0435\u0432\u0430 \u0431\u0435\u0440\u043A\u0443\u0442\u0430.
      \u041A\u0440\u0430\u0441\u0438\u0432\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C?"
    kazakhText: "\u0411\u0430\u043B\u0430 \u0434\u0430\u0443\u044B\u0441: \u049A\u0430\u0440\u0430\u04A3\u044B\u0437\u0448\u044B, 
      \u043C\u0435\u043D \u0434\u0435 \u0430\u0493\u0430\u0448\u0442\u0430\u043D
      \u0431\u04AF\u0440\u043A\u0456\u0442 \u0436\u0430\u0441\u0430\u0434\u044B\u043C.
      \u04D8\u0434\u0435\u043C\u0456 \u043C\u0435? "
    englishText: "Child\u2019s voice: \u2014 Look, I carved an eagle from wood too.
      Isn\u2019t it beautiful?"
    duration: 4
