  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "2 \u0410\u0431\u0430\u0438\u0306 \u041C\u0435\u043D \u0435\u0442\u0435\u043A
    \u041C\u041E\u0414\u0423\u041B\u042C 2"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0410\u0431\u0430\u0439: \u2013 \u0421\u0435\u043C\u0435\u0439\u043D\u044B\u0435
      \u0437\u0430\u0431\u043E\u0442\u044B \u0441\u0432\u044F\u0437\u0430\u043B\u0438
      \u043C\u043D\u0435 \u0440\u0443\u043A\u0438, \u0438 \u044F \u043D\u0435 \u0441\u043C\u043E\u0433
      \u043F\u043E-\u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u043C\u0443 \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C
      \u0441\u0435\u0431\u044F \u043D\u0430\u0443\u043A\u0435. "
    kazakhText: "\u0410\u0431\u0430\u0439: - \u041C\u0435\u043D \u0435\u0442\u0435\u043A
      \u0431\u0430\u0441\u0442\u044B \u0431\u043E\u043B\u044B\u043F, \u0431\u0456\u043B\u0456\u043C
      \u049B\u0443\u0430 \u0430\u043B\u043C\u0430\u0434\u044B\u043C. "
    englishText: "Abai: - The burdens of life bound my hands\u2026 I was never truly
      able to devote myself entirely to the pursuit of knowledge."
    duration: 4
  - russianText: "\u0425\u043E\u0442\u0435\u043B\u043E\u0441\u044C \u0431\u044B,
      \u0447\u0442\u043E\u0431\u044B \u043C\u043E\u044F \u043C\u0435\u0447\u0442\u0430
      \u0432\u0441\u0451 \u0436\u0435 \u0441\u0442\u0430\u043B\u0430 \u044F\u0432\u044C\u044E\u2026"
    kazakhText: "\u0421\u043E\u043B \u0430\u0440\u043C\u0430\u043D\u044B\u043C \u0448\u044B\u043D\u0493\u0430
      \u0430\u0439\u043D\u0430\u043B\u0441\u0430 \u0434\u0435\u0439\u043C\u0456\u043D..."
    englishText: "I only wish that my dream might one day come true through you\u2026"
    duration: 3
