  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "4 \u0410\u0431\u0430\u0438\u0306 \u0410\u0434\u0430\u043C \u049B\u044B\u0440\u044B\u049B
    \u0436\u0430\u0441\u044B\u043D\u0430 \u041C\u041E\u0414\u0423\u041B\u042C 2"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0410\u0431\u0430\u0439: \u2013 \u0414\u043E \u0441\u043E\u0440\u043E\u043A\u0430
      \u043B\u0435\u0442 \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u043D\u0430\u043A\u0430\u043F\u043B\u0438\u0432\u0430\u0435\u0442
      \u0437\u043D\u0430\u043D\u0438\u044F, \u0430 \u043A \u0441\u043E\u0440\u043E\u043A\u0430
      \u0434\u043E\u0441\u0442\u0438\u0433\u0430\u0435\u0442 \u0437\u0440\u0435\u043B\u043E\u0441\u0442\u0438."
    kazakhText: "\u0410\u0431\u0430\u0439: - \u0410\u0434\u0430\u043C \u049B\u044B\u0440\u044B\u049B
      \u0436\u0430\u0441\u044B\u043D\u0430 \u0434\u0435\u0439\u0456\u043D \u0431\u0456\u043B\u0456\u043C
      \u0436\u0438\u043D\u0430\u0439\u0434\u044B, \u049B\u044B\u0440\u044B\u049B\u049B\u0430
      \u043A\u0435\u043B\u0433\u0435\u043D\u0434\u0435 \u043A\u0435\u043C\u0435\u043B\u0456\u043D\u0435
      \u0442\u043E\u043B\u0430\u0434\u044B."
    englishText: 'Abai: - Until the age of forty, a person gathers knowledge; by
      forty, he reaches true maturity.

'
    duration: 8
  - russianText: "\u0412 \u044D\u0442\u0443 \u043F\u043E\u0440\u0443 \u043A\u0440\u0435\u043F\u043D\u0443\u0442
      \u0438 \u0440\u0430\u0437\u0443\u043C, \u0438 \u0432\u043E\u043B\u044F."
    kazakhText: "\u0421\u043E\u043B \u0443\u0430\u049B\u044B\u0442\u0442\u0430 \u0430\u049B\u044B\u043B-\u043E\u0439\u044B
      \u0434\u0430, \u0436\u0456\u0433\u0435\u0440-\u049B\u0430\u0439\u0440\u0430\u0442\u044B
      \u0434\u0430 \u0436\u0435\u0442\u0456\u043B\u0435\u0434\u0456."
    englishText: It is then that both the mind and the spirit grow strong.
    duration: 5
  - russianText: "\u0427\u0435\u0440\u0435\u0437 \u0442\u0440\u0438 \u0433\u043E\u0434\u0430
      \u0442\u0435\u0431\u0435 \u0438\u0441\u043F\u043E\u043B\u043D\u0438\u0442\u0441\u044F
      \u0441\u043E\u0440\u043E\u043A."
    kazakhText: "\u0415\u043D\u0434\u0456 \u04AF\u0448 \u0436\u044B\u043B\u0434\u0430
      \u0441\u0435\u043D \u049B\u044B\u0440\u044B\u049B\u049B\u0430 \u0442\u043E\u043B\u0430\u0441\u044B\u04A3."
    englishText: In three years, you too will turn forty.
    duration: 3
  - russianText: "\u0422\u044B \u0445\u043E\u0440\u043E\u0448\u043E \u0432\u043B\u0430\u0434\u0435\u0435\u0448\u044C
      \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u043C\u0438 \u044F\u0437\u044B\u043A\u0430\u043C\u0438.
      \u0425\u043E\u0447\u0443, \u0447\u0442\u043E\u0431\u044B \u0442\u044B \u0443\u0432\u0438\u0434\u0435\u043B
      \u043C\u0438\u0440"
    kazakhText: "\u0428\u044B\u0493\u044B\u0441 \u0442\u0456\u043B\u0434\u0435\u0440\u0456\u043D
      \u0436\u0435\u0442\u0456\u043A \u0431\u0456\u043B\u0435\u0442\u0456\u043D\u0456\u04A3
      \u0431\u0430\u0440, \u0436\u0435\u0440 \u0442\u0430\u043D\u044B\u043F, "
    englishText: You know the Eastern languages well. I want you to see the world
    duration: 4
  - russianText: "\u0440\u0430\u0441\u0448\u0438\u0440\u0438\u043B \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044F,
      \u043F\u0440\u0438\u043A\u043E\u0441\u043D\u0443\u043B\u0441\u044F \u043A \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439
      \u043D\u0430\u0443\u043A\u0435\u2026 \u041F\u043E\u0435\u0434\u0435\u0448\u044C?"
    kazakhText: "\u0431\u0456\u043B\u0456\u043C \u0430\u043B\u0441\u0430\u04A3 \u0434\u0435\u0439\u043C\u0456\u043D... 
      \u0411\u0430\u0440\u0430\u0441\u044B\u04A3 \u0431\u0430?"
    englishText: "broaden your understanding, and touch the depths of true scholarship\u2026
      Will you go?"
    duration: 4
