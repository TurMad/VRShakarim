  m_Script: {fileID: 11500000, guid: ede75b7c314e4f84c83ff76fe2d414a4, type: 3}
  m_Name: BookInstr
  m_EditorClassIdentifier: Assembly-CSharp::InstructionSubtitleSO
  russianText: "\u041D\u0430\u0436\u0438\u043C\u0430\u0439\u0442\u0435 \u0442\u0440\u0438\u0433\u0433\u0435\u0440\u044B,
    \u0447\u0442\u043E\u0431\u044B \u043F\u0435\u0440\u0435\u043B\u0438\u0441\u0442\u044B\u0432\u0430\u0442\u044C
    \u043A\u043D\u0438\u0433\u0443. \u041D\u0430\u0436\u043C\u0438\u0442\u0435 X,
    \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u043A\u0440\u044B\u0442\u044C \u043A\u043D\u0438\u0433\u0443."
  kazakhText: "\u041A\u0456\u0442\u0430\u043F\u0442\u044B \u043F\u0430\u0440\u0430\u049B\u0442\u0430\u0443
    \u04AF\u0448\u0456\u043D \u0442\u0440\u0438\u0433\u0433\u0435\u0440\u043B\u0435\u0440\u0434\u0456
    \u0431\u0430\u0441\u044B\u04A3\u044B\u0437. \u041A\u0456\u0442\u0430\u043F\u0442\u044B
    \u0436\u0430\u0431\u0443 \u04AF\u0448\u0456\u043D X \u0431\u0430\u0442\u044B\u0440\u043C\u0430\u0441\u044B\u043D
    \u0431\u0430\u0441\u044B\u04A3\u044B\u0437."
  englishText: Press the triggers to turn the book pages. Press X to close the book.
