--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "9 \u0428\u0430\u043A\u0430\u0440\u0438\u043C \u0410\u0434\u0430\u043C\u0434\u044B\u049B
    \u0431\u043E\u0440\u044B\u0448\u044B\u04A3"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0427\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0438\u0439
      \u0434\u043E\u043B\u0433 \u0442\u0432\u043E\u0439"
    kazakhText: "\u0410\u0434\u0430\u043C\u0434\u044B\u049B \u0431\u043E\u0440\u044B\u0448\u044B\u04A3"
    englishText: Your human duty is this
    duration: 2
  - russianText: "\u0421\u043B\u0443\u0436\u0438\u0442\u044C \u0441\u0432\u043E\u0435\u043C\u0443
      \u043D\u0430\u0440\u043E\u0434\u0443."
    kazakhText: "\u0425\u0430\u043B\u049B\u044B\u04A3\u0430 \u0435\u04A3\u0431\u0435\u043A
      \u049B\u044B\u043B."
    englishText: To serve your people well.
    duration: 2
  - russianText: "\u041D\u0435 \u0441\u0445\u043E\u0434\u044F \u0441 \u043F\u0443\u0442\u0438
      \u043F\u0440\u0430\u0432\u0434\u044B,"
    kazakhText: "\u0410\u049B \u0436\u043E\u043B\u0434\u0430\u043D \u0430\u0439\u043D\u044B\u043C\u0430\u0439"
    englishText: Never stray from the righteous path,
    duration: 2
  - russianText: "\u0411\u0435\u0440\u0435\u0433\u0438 \u0447\u0435\u0441\u0442\u044C
      \u0441\u0432\u043E\u044E \u0441\u043C\u043E\u043B\u043E\u0434\u0443."
    kazakhText: "\u0410\u0440 \u0441\u0430\u049B\u0442\u0430, \u043E\u043D\u044B
      \u0431i\u043B."
    englishText: Guard your honor faithfully.
    duration: 2
  - russianText: "\u0421\u0442\u0440\u0435\u043C\u0438\u0441\u044C \u043A \u0437\u043D\u0430\u043D\u0438\u044F\u043C
      \u0438 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0443, \u041F\u043E\u0437\u043D\u0430\u0432\u0430\u0439
      \u0438\u0445 \u043D\u0435\u0443\u0441\u0442\u0430\u043D\u043D\u043E."
    kazakhText: "\u0422\u0430\u043B\u0430\u043F\u0442\u0430\u043D \u0434\u0430 \u0431i\u043Bi\u043C
      \u043C\u0435\u043D \u04E9\u043D\u0435\u0440 \u04AF\u0439\u0440\u0435\u043D,"
    englishText: Seek knowledge and seek the arts, Learn with tireless devotion.
    duration: 4
  - russianText: "\u0411\u0435\u0437 \u043D\u0430\u0443\u043A\u0438,"
    kazakhText: "\u0411i\u043Bi\u043C\u0441i\u0437,"
    englishText: Without wisdom,
    duration: 1.5
  - russianText: "\u0411\u0435\u0437 \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u0430"
    kazakhText: "\u04E8\u043D\u0435\u0440\u0441i\u0437,"
    englishText: Without mastery,
    duration: 1.5
  - russianText: "\u0420\u0430\u0437\u0443\u043C \u043C\u0435\u0440\u043A\u043D\u0435\u0442
      \u0431\u0435\u0437\u0432\u043E\u0437\u0432\u0440\u0430\u0442\u043D\u043E."
    kazakhText: "\u0411\u043E\u043B\u0430\u0434\u044B \u0430\u049B\u044B\u043B \u0442\u04B1\u043B."
    englishText: The mind itself grows dim.
    duration: 2
