  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "6 \u0410\u0431\u0430\u0438\u0306 \u0410\u0444\u0438\u043D-\u0413\u0440\u0435\u043A
    \u0431\u0456\u043B\u0456\u043C\u0456 \u041C\u043E\u0434\u0443\u043B\u044C 2"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0410\u0431\u0430\u0439: \u2013 \u0410\u0444\u0438\u043D\u0441\u043A\u0430\u044F
      \u0438 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0430\u044F \u043C\u0443\u0434\u0440\u043E\u0441\u0442\u044C
      \u0441\u043E\u0431\u0440\u0430\u043D\u0430 \u0432 \u0421\u0442\u0430\u043C\u0431\u0443\u043B\u0435
      \u2013 \u0442\u0430\u043C \u0442\u044B \u043D\u0430\u0439\u0434\u0451\u0448\u044C
      \u043C\u043D\u043E\u0433\u043E\u0435."
    kazakhText: "\u0410\u0431\u0430\u0439: - \u0410\u0444\u0438\u043D-\u0413\u0440\u0435\u043A
      \u0431\u0456\u043B\u0456\u043C\u0456 \u0421\u0442\u0430\u043C\u0431\u043E\u043B\u0493\u0430
      \u0436\u0438\u043D\u0430\u043B\u0493\u0430\u043D, \u0441\u043E\u0434\u0430\u043D
      \u0442\u0430\u0431\u044B\u043B\u0430\u0434\u044B."
    englishText: 'Abai: - The wisdom of Athens and Greece has gathered in Istanbul
      - there you shall find much.

'
    duration: 5
  - russianText: "\u0410\u0440\u0430\u0431\u0441\u043A\u0430\u044F \u043D\u0430\u0443\u043A\u0430
      \u0438 \u0437\u043D\u0430\u043D\u0438\u0435 \u2013 \u0432 \u041C\u0435\u043A\u043A\u0435,
      \u0445\u043E\u0442\u044F, \u0434\u0443\u043C\u0430\u0435\u0442\u0441\u044F
      \u043C\u043D\u0435, \u0435\u0449\u0451 \u0431\u043E\u043B\u044C\u0448\u0435
      \u0441\u043E\u043A\u0440\u043E\u0432\u0438\u0449 \u0437\u043D\u0430\u043D\u0438\u044F
      \u0445\u0440\u0430\u043D\u0438\u0442 \u041C\u0435\u0434\u0438\u043D\u0430."
    kazakhText: "\u0410\u0440\u0430\u0431 \u0431\u0456\u043B\u0456\u043C\u0456 \u2013 
      \u041C\u0435\u043A\u043A\u0435\u0434\u0435, \u0431\u0456\u0440\u0430\u049B
      \u043C\u0435\u043D\u0456\u04A3\u0448\u0435, \u041C\u0435\u043A\u043A\u0435\u0434\u0435\u043D
      \u0433\u04E9\u0440\u0456 \u041C\u0435\u0434\u0438\u043D\u0430\u0434\u0430\u043D
      \u043A\u04E9\u0431\u0456\u0440\u0435\u043A \u0442\u0430\u0431\u044B\u043B\u043C\u0430\u0493\u044B
      \u043A\u0435\u0440\u0435\u043A."
    englishText: Arab scholarship lives in Mecca, though I believe even greater treasures
      of knowledge await in Medina.
    duration: 8
  - russianText: "\u0418 \u0435\u0449\u0451 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0448\u044C\u0441\u044F
      \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0443\u044E
      \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443 \u0432 \u0415\u0433\u0438\u043F\u0442\u0435."
    kazakhText: "\u0416\u04D9\u043D\u0435 \u041C\u044B\u0441\u044B\u0440\u0434\u0430\u0493\u044B
      \u0415\u0441\u043A\u0435\u043D\u0434\u0456\u0440 \u043A\u0456\u0442\u0430\u043F\u0445\u0430\u043D\u0430\u0441\u044B\u043D\u0430 
      \u0431\u0430\u0440\u0430\u0441\u044B\u04A3."
    englishText: And you must also travel to the Library of Alexandria in Egypt.
    duration: 4
  - russianText: "\u041F\u043E\u0441\u0435\u0442\u0438\u0448\u044C \u044D\u0442\u0438
      \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u044B\u0435 \u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
      \u043C\u0435\u0441\u0442\u0430, \u0441\u043E\u0431\u0435\u0440\u0451\u0448\u044C
      \u043D\u0443\u0436\u043D\u044B\u0435 \u043A\u043D\u0438\u0433\u0438, \u043F\u043E\u043F\u043E\u043B\u043D\u0438\u0448\u044C
      \u0441\u0432\u043E\u0438 \u0437\u043D\u0430\u043D\u0438\u044F \u0438 \u0432\u0435\u0440\u043D\u0451\u0448\u044C\u0441\u044F."
    kazakhText: "\u041E\u0441\u044B \u0442\u04E9\u0440\u0442 \u0436\u0435\u0440\u0433\u0435
      \u0431\u0430\u0440\u044B\u043F, \u0442\u0430\u0440\u0438\u0445\u0438 \u043E\u0440\u044B\u043D\u0434\u0430\u0440\u0434\u044B
      \u0430\u0440\u0430\u043B\u0430\u043F, \u043A\u0435\u0440\u0435\u043A \u043A\u0456\u0442\u0430\u043F\u0442\u0430\u0440\u044B\u04A3\u0434\u044B
      \u0430\u043B\u044B\u043F, \u0431\u0456\u043B\u0456\u043C\u0456\u04A3\u0434\u0456
      \u0442\u043E\u043B\u044B\u049B\u0442\u044B\u0440\u044B\u043F \u049B\u0430\u0439\u0442\u0430\u0441\u044B\u04A3."
    englishText: Visit these sacred and historic lands, gather the books you need,
      deepen your learning, and return enriched in spirit and wisdom.
    duration: 8
  - russianText: "\u0414\u0435\u043D\u0435\u0433 \u043D\u0430 \u0434\u043E\u0440\u043E\u0433\u0443
      \u0438 \u043D\u0430 \u043F\u043E\u043A\u0443\u043F\u043A\u0443 \u043A\u043D\u0438\u0433
      \u044F \u0434\u0430\u043C \u0441\u0430\u043C."
    kazakhText: "\u0421\u0430\u0442\u044B\u043F \u0430\u043B\u0430\u0442\u044B\u043D
      \u043A\u0456\u0442\u0430\u043F\u0442\u0430\u0440\u044B\u04A3\u0430, \u0436\u043E\u043B
      \u049B\u0430\u0440\u0430\u0436\u0430\u0442\u044B\u04A3\u0430 \u0436\u0435\u0442\u0435\u0440\u043B\u0456\u043A
      \u043F\u04B1\u043B\u0434\u044B \u04E9\u0437\u0456\u043C \u0431\u0435\u0440\u0435\u043C."
    englishText: I will provide the money for your journey and for the books.
    duration: 6
  - russianText: "\u0415\u0441\u043B\u0438 \u0441\u043E\u0433\u043B\u0430\u0441\u0435\u043D
      \u2013 \u0434\u0430\u0439 \u0440\u0443\u043A\u0443."
    kazakhText: "\u041E\u0441\u044B\u0493\u0430\u043D \u043A\u0435\u043B\u0456\u0441\u0441\u0435\u04A3,
      \u049B\u043E\u043B\u044B\u04A3\u0434\u044B \u04D9\u043A\u0435\u043B"
    englishText: "If you agree \u2014 give me your hand."
    duration: 3
