  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "7 \u0428\u0430\u043A\u0430\u0440\u0438\u043C \u049A\u0430\u0440\u0430\u0436\u0430\u0442
    \u0441\u0456\u0437\u0434\u0435\u043D \u041C\u041E\u0414\u0423\u041B\u042C 2"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0428\u04D9\u043A\u04D9\u0440\u0456\u043C: - \u049A\u0430\u0440\u0430\u0436\u0430\u0442
      \u0441\u0456\u0437\u0434\u0435\u043D \u0431\u043E\u043B\u0441\u0430, \u043C\u0435\u043D
      \u0431\u0456\u043B\u0456\u043C \u0430\u043B\u0430\u0442\u044B\u043D \u0431\u043E\u043B\u0441\u0430\u043C,
      \u0431\u0430\u0440\u0430\u043C\u044B\u043D!\xBB"
    kazakhText: "\u0428\u0430\u043A\u0430\u0440\u0438\u043C: \u2013 \u0415\u0441\u043B\u0438
      \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430 \u043E\u0442 \u0432\u0430\u0441,
      \u0430 \u043F\u0443\u0442\u044C \u0432\u0435\u0434\u0451\u0442 \u043A \u0437\u043D\u0430\u043D\u0438\u044F\u043C
      \u2013 \u044F \u0433\u043E\u0442\u043E\u0432 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C\u0441\u044F!"
    englishText: "Shakarim: - If the road leads to knowledge, and your blessing guides
      me \u2014 I am ready to depart this very day!\r\n"
    duration: 6
