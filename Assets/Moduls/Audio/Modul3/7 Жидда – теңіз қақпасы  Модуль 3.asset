MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "7 \u0416\u0438\u0434\u0434\u0430 \u2013 \u0442\u0435\u04A3\u0456\u0437
    \u049B\u0430\u049B\u043F\u0430\u0441\u044B  \u041C\u043E\u0434\u0443\u043B\u044C
    3"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0414\u0436\u0438\u0434\u0434\u0430 \u2014 \u043C\u043E\u0440\u0441\u043A\u0438\u0435
      \u0432\u0440\u0430\u0442\u0430 \u041C\u0435\u043A\u043A\u0438, \u0433\u043B\u0430\u0432\u043D\u044B\u0439
      \u043F\u0443\u0442\u044C, \u0432\u0435\u0434\u0443\u0449\u0438\u0439 \u043A
      \u0441\u0432\u044F\u0442\u044B\u043D\u0435 \u0438\u0441\u043B\u0430\u043C\u0430."
    kazakhText: "\u0416\u0438\u0434\u0434\u0430 \u2013 \u0442\u0435\u04A3\u0456\u0437
      \u049B\u0430\u049B\u043F\u0430\u0441\u044B \u043D\u0435\u043C\u0435\u0441\u0435
      \u041C\u0435\u043A\u043A\u0435\u0433\u0435 \u0430\u043F\u0430\u0440\u0430\u0442\u044B\u043D
      \u043D\u0435\u0433\u0456\u0437\u0433\u0456 \u0436\u043E\u043B."
    englishText: "Jeddah was the sea gate to Mecca \u2014 the principal passage leading
      to Islam\u2019s holiest sanctuary."
    duration: 4
  - russianText: "\u0417\u0434\u0435\u0441\u044C \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0438\u0441\u044C
      \u0442\u0430\u043C\u043E\u0436\u0435\u043D\u043D\u044B\u0435, \u0441\u0430\u043D\u0438\u0442\u0430\u0440\u043D\u044B\u0435
      \u0438 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C\u043D\u044B\u0435
      \u043F\u0443\u043D\u043A\u0442\u044B."
    kazakhText: "\u041C\u04B1\u043D\u0434\u0430 \u043A\u0435\u0434\u0435\u043D\u0434\u0456\u043A,
      \u0441\u0430\u043D\u0438\u0442\u0430\u0440\u043B\u044B\u049B \u0436\u04D9\u043D\u0435
      \u0434\u0456\u043D\u0438 \u0431\u0430\u049B\u044B\u043B\u0430\u0443 \u04E9\u0442\u043A\u0435\u043B\u0456
      \u0431\u0430\u0440."
    englishText: Customs, sanitary, and religious checkpoints were located here.
    duration: 5
  - russianText: "\u041F\u0430\u043B\u043E\u043C\u043D\u0438\u043A\u0438 \u043F\u043E\u0434\u043E\u043B\u0433\u0443
      \u043E\u0436\u0438\u0434\u0430\u043B\u0438 \u0441\u0432\u043E\u0435\u0439 \u043E\u0447\u0435\u0440\u0435\u0434\u0438
      \u043D\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0435. \u041F\u043E\u0441\u043B\u0435
      \u043F\u0440\u043E\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0432\u0441\u0435\u0445
      \u043F\u0440\u043E\u0432\u0435\u0440\u043E\u043A"
    kazakhText: "\u0428\u0435\u043A\u0430\u0440\u0430\u0434\u0430 \u0431\u0456\u0440
      \u043A\u04AF\u043D \u043A\u0435\u0437\u0435\u043A\u0442\u0435 \u0442\u04B1\u0440\u044B\u043F,
      \u0448\u0435\u043A\u0430\u0440\u0430 \u04E9\u0442\u043A\u0435\u043D \u0441\u043E\u04A3,"
    englishText: Pilgrims often waited long hours at the border before being allowed
      to continue. After passing inspection,
    duration: 3
  - russianText: "\u043E\u043D\u0438 \u0433\u0440\u0443\u0437\u0438\u043B\u0438 \u043F\u043E\u043A\u043B\u0430\u0436\u0443
      \u043D\u0430 \u0432\u0435\u0440\u0431\u043B\u044E\u0434\u043E\u0432 \u0438
      \u0435\u0449\u0451 \u0442\u0440\u0438 \u0434\u043D\u044F \u0434\u043E\u0431\u0438\u0440\u0430\u043B\u0438\u0441\u044C
      \u0434\u043E \u041C\u0435\u043A\u043A\u0438 \u043F\u0435\u0448\u043A\u043E\u043C,
      \u043F\u0440\u0435\u043E\u0434\u043E\u043B\u0435\u0432\u0430\u044F \u043F\u0430\u043B\u044F\u0449\u0438\u0439
      \u0437\u043D\u043E\u0439 \u0438 \u0431\u0435\u0441\u043A\u0440\u0430\u0439\u043D\u0438\u0435
      \u043F\u0435\u0441\u043A\u0438."
    kazakhText: "\u049B\u0430\u0436\u044B\u043B\u0430\u0440 \u041C\u0435\u043A\u043A\u0435\u0433\u0435
      \u0436\u0435\u0442\u0443 \u04AF\u0448\u0456\u043D \u0442\u04AF\u0439\u0435\u0433\u0435
      \u0436\u04AF\u043A \u0430\u0440\u0442\u044B\u043F, \u04AF\u0448 \u043A\u04AF\u043D
      \u0436\u0430\u044F\u0443 \u0436\u04AF\u0440\u0456\u043F \u0431\u0430\u0440\u0493\u0430\u043D."
    englishText: they loaded their belongings onto camels and walked for three more
      days across burning sands and relentless heat to reach Mecca.
    duration: 4
  - russianText: "\u041E\u0431 \u044D\u0442\u043E\u043C \u0410\u0445\u0430\u0442
      \u0428\u0430\u043A\u0430\u0440\u0438\u043C\u0443\u043B\u044B \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B
      \u0442\u0430\u043A:"
    kazakhText: "\u0411\u04B1\u043B \u0436\u04E9\u043D\u0456\u043D\u0434\u0435 \u0410\u0445\u0430\u0442
      \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C\u04B1\u043B\u044B\u043D\u044B\u04A3
      \u0435\u0441\u0442\u0435\u043B\u0456\u043A \u0436\u0430\u0437\u0431\u0430\u0441\u044B:"
    englishText: 'Akhat Shakarimuly later recalled:'
    duration: 4
  - russianText: "\xAB\u0412\u043E \u0432\u0440\u0435\u043C\u044F \u044D\u0442\u043E\u0433\u043E
      \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F \u0428\u0430\u043A\u0430\u0440\u0438\u043C
      \u043D\u0435 \u0437\u0430\u0431\u043E\u043B\u0435\u043B."
    kazakhText: "\xAB\u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u0431\u04B1\u043B
      \u0441\u0430\u043F\u0430\u0440\u0434\u0430 \u0430\u0443\u044B\u0440\u0493\u0430\u043D
      \u0436\u043E\u049B."
    englishText: "\u201CDuring this journey, Shakarim never fell ill."
    duration: 3
  - russianText: "\u0417\u0430\u043A\u0430\u043B\u0451\u043D\u043D\u044B\u0439 \u0441\u0443\u0440\u043E\u0432\u043E\u0439
      \u0436\u0438\u0437\u043D\u044C\u044E \u043A\u043E\u0447\u0435\u0432\u043D\u0438\u043A\u043E\u0432,
      \u043E\u043D \u043E\u0442\u043B\u0438\u0447\u0430\u043B\u0441\u044F \u043D\u0435\u043E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u043E\u0439
      \u0432\u044B\u043D\u043E\u0441\u043B\u0438\u0432\u043E\u0441\u0442\u044C\u044E."
    kazakhText: "\u041A\u04E9\u0448\u043F\u0435\u043B\u0456\u043B\u0435\u0440\u0434\u0456\u04A3
      \u049B\u0430\u0442\u0430\u043B \u0442\u04B1\u0440\u043C\u044B\u0441\u044B\u043D\u0430
      \u04D9\u0431\u0434\u0435\u043D \u0448\u044B\u043D\u044B\u049B\u049B\u0430\u043D,
      \u0442\u04E9\u0437\u0456\u043C\u0434\u0456 \u0435\u0434\u0456."
    englishText: Hardened by the harsh life of the nomads, he possessed extraordinary
      endurance.
    duration: 4
  - russianText: "\u041F\u043E \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E
      \u0441\u043E \u0441\u0432\u043E\u0438\u043C\u0438 \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430\u043C\u0438
      \u043E\u043D \u043B\u0435\u0433\u0447\u0435 \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u043B
      \u0442\u044F\u0436\u0451\u043B\u0443\u044E \u0434\u043E\u0440\u043E\u0433\u0443. "
    kazakhText: "\u0421\u0430\u043F\u0430\u0440\u043B\u0430\u0441\u0442\u0430\u0440\u044B\u043D\u0430
      \u049B\u0430\u0440\u0430\u0493\u0430\u043D\u0434\u0430 \u049B\u0438\u044B\u043D
      \u0436\u043E\u043B\u0434\u044B \u0434\u0430 \u0436\u0435\u04A3\u0456\u043B
      \u04E9\u0442\u0442\u0456. "
    englishText: Compared to his companions, he bore the difficult road more easily.
    duration: 3
  - russianText: "\u041F\u043E\u043C\u043E\u0433\u0430\u043B \u043E\u0442\u0441\u0442\u0430\u044E\u0449\u0438\u043C,
      \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B \u0441\u0442\u0430\u0440\u0438\u043A\u043E\u0432
      \u0438 \u043A\u0430\u043A \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0445\u0430\u0434\u0436\u0430,"
    kazakhText: "\u0416\u043E\u043B\u0434\u0430 \u049B\u0430\u043B\u0493\u0430\u043D\u0434\u0430\u0440\u0493\u0430
      \u043A\u04E9\u043C\u0435\u043A\u0442\u0435\u0441\u0456\u043F, \u043A\u0430\u0440\u0442\u0442\u0430\u0440\u0434\u044B
      \u0441\u04AF\u0439\u0435\u043C\u0435\u043B\u0434\u0435\u043F,"
    englishText: He helped those who lagged behind, supported the elderly
    duration: 4
  - russianText: "\u0442\u0430\u043A \u0438 \u043D\u0430 \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u043C
      \u043F\u0443\u0442\u0438 \u0441\u0442\u043E\u0439\u043A\u043E \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u043B
      \u0432\u0441\u0435 \u0432\u044B\u043F\u0430\u0432\u0448\u0438\u0435 \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F,"
    kazakhText: "\u049B\u0430\u0436\u044B\u043B\u044B\u049B \u043A\u0435\u0437\u0456\u043D\u0434\u0435
      \u0434\u0435, \u04AF\u0439\u0433\u0435 \u049B\u0430\u0439\u0442\u0430\u0440
      \u0436\u043E\u043B\u0434\u0430 \u0434\u0430 \u0431\u0430\u0441\u044B\u043D\u0430
      \u0442\u04AF\u0441\u043A\u0435\u043D \u0431\u0435\u0439\u043D\u0435\u0442\u043A\u0435
      \u0442\u04E9\u0437\u0456\u043F \u0431\u0430\u0493\u044B\u043F,"
    englishText: and both during the pilgrimage and on the journey home endured every
      hardship
    duration: 5
  - russianText: "\u043D\u0438 \u0440\u0430\u0437\u0443 \u043D\u0435 \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0432\u0448\u0438\u0441\u044C
      \u043D\u0430 \u0441\u0443\u0434\u044C\u0431\u0443\xBB."
    kazakhText: "\u0448\u0430\u0493\u044B\u043C \u0430\u0439\u0442\u044B\u043F \u043A\u04E9\u0440\u0433\u0435\u043D
      \u0436\u043E\u049B\xBB \u2013 \u0434\u0435\u043F \u0436\u0430\u0437\u0430\u0434\u044B."
    englishText: "without once complaining about his fate.\u201D"
    duration: 4
