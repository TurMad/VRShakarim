  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "10 \u041D\u0430\u0437\u0430\u0440 \u0430\u0443\u0434\u0430\u0440\u044B\u04A3\u044B\u0437!
    \u041C\u043E\u0434\u0443\u043B\u044C 3"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0412\u043D\u0438\u043C\u0430\u043D\u0438\u0435! \u041E\u0431\u0445\u043E\u0434
      \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u043E\u0442 \u0443\u0433\u043B\u0430,
      \u0433\u0434\u0435 \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D
      \u0427\u0451\u0440\u043D\u044B\u0439 \u043A\u0430\u043C\u0435\u043D\u044C \u2014
      \u0425\u0430\u0434\u0436\u0430\u0440 \u0430\u043B\u044C-\u0410\u0441\u0432\u0430\u0434."
    kazakhText: "\u041D\u0430\u0437\u0430\u0440 \u0430\u0443\u0434\u0430\u0440\u044B\u04A3\u044B\u0437!
      \xAB\u049A\u0430\u0440\u0430 \u0442\u0430\u0441\xBB (\u0425\u0430\u0436\u0430\u0440\u0443\u043B-\u0430\u0441\u0443\u0430\u0434)
      \u043E\u0440\u043D\u0430\u043B\u0430\u0441\u049B\u0430\u043D \u0431\u04B1\u0440\u044B\u0448\u0442\u0430\u043D
      \u0431\u0430\u0441\u0442\u0430\u043B\u0430\u0434\u044B.:"
    englishText: "Attention! The ritual begins at the corner where the Black Stone
      \u2014 Hajar al-Aswad \u2014 is located."
    duration: 6
  - russianText: "\u042D\u0442\u043E \u043C\u0435\u0441\u0442\u043E \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u043E
      \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C \u0437\u043D\u0430\u043A\u043E\u043C."
    kazakhText: "\u0431\u04B1\u043B \u0436\u0435\u0440 \u0430\u0440\u043D\u0430\u0439\u044B
      \u0431\u0435\u043B\u0433\u0456\u043C\u0435\u043D \u0431\u0435\u043B\u0433\u0456\u043B\u0435\u043D\u0433\u0435\u043D."
    englishText: This place is marked with a special sign.
    duration: 2
  - russianText: "\u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
      \u041A\u0430\u0430\u0431\u0430 \u0434\u043E\u043B\u0436\u043D\u0430 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u043F\u043E \u043B\u0435\u0432\u0443\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u0443,"
    kazakhText: "\u0421\u0456\u0437 \u049A\u0430\u0493\u0431\u0430\u043D\u044B \u04E9\u0437\u0456\u04A3\u0456\u0437\u0434\u0456\u04A3
      \u0441\u043E\u043B \u0436\u0430\u0493\u044B\u04A3\u044B\u0437\u0434\u0430 \u04B1\u0441\u0442\u0430\u043F,"
    englishText: During the movement, the Kaaba must remain on your left side,
    duration: 3
  - russianText: "\u0430 \u043E\u0431\u0445\u043E\u0434 \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u0435\u0442\u0441\u044F
      \u043F\u0440\u043E\u0442\u0438\u0432 \u0447\u0430\u0441\u043E\u0432\u043E\u0439
      \u0441\u0442\u0440\u0435\u043B\u043A\u0438."
    kazakhText: "\u0441\u0430\u0493\u0430\u0442 \u0442\u0456\u043B\u0456\u043D\u0435
      \u049B\u0430\u0440\u0441\u044B \u0431\u0430\u0493\u044B\u0442\u0442\u0430 \u049B\u043E\u0437\u0493\u0430\u043B\u0443\u044B\u04A3\u044B\u0437
      \u049B\u0430\u0436\u0435\u0442."
    englishText: and the circumambulation is performed counterclockwise.
    duration: 3
