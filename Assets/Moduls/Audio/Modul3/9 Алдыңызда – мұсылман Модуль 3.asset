MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "9 \u0410\u043B\u0434\u044B\u04A3\u044B\u0437\u0434\u0430 \u2013 \u043C\u04B1\u0441\u044B\u043B\u043C\u0430\u043D
    \u041C\u043E\u0434\u0443\u043B\u044C 3"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u041F\u0435\u0440\u0435\u0434 \u0432\u0430\u043C\u0438 \u2014
      \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0430\u044F \u041C\u0435\u043A\u043A\u0430,
      \u0434\u0443\u0445\u043E\u0432\u043D\u043E\u0435 \u0441\u0435\u0440\u0434\u0446\u0435
      \u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0441\u043A\u043E\u0433\u043E
      \u043C\u0438\u0440\u0430, \u041A\u0430\u0430\u0431\u0430 \u0438 \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u044B\u0439
      \u0427\u0451\u0440\u043D\u044B\u0439 \u043A\u0430\u043C\u0435\u043D\u044C."
    kazakhText: "\u0410\u043B\u0434\u044B\u04A3\u044B\u0437\u0434\u0430 \u2013 \u043C\u04B1\u0441\u044B\u043B\u043C\u0430\u043D
      \u04AF\u043C\u043C\u0435\u0442\u0456\u043D\u0456\u04A3 \u049B\u0430\u0441\u0438\u0435\u0442\u0442\u0456
      \u043C\u0435\u043A\u0435\u043D\u0456 \u2013 \u041C\u0435\u043A\u043A\u0435,
      \u049B\u0430\u0441\u0438\u0435\u0442\u0442\u0456 \u049B\u0430\u0440\u0430 \u0442\u0430\u0441,
      \u049A\u0430\u0493\u0431\u0430."
    englishText: "Before you stands holy Mecca \u2014 the spiritual heart of the
      Muslim world \u2014 the Kaaba and the sacred Black Stone."
    duration: 7
  - russianText: "\u0421\u0435\u0439\u0447\u0430\u0441 \u0432\u044B \u0432 \u0432\u0438\u0440\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u043C
      \u0444\u043E\u0440\u043C\u0430\u0442\u0435 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u0442\u0435
      \u0442\u0430\u0432\u0430\u0444 \u2014 \u043E\u0434\u0438\u043D \u0438\u0437
      \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0445 \u043E\u0431\u0440\u044F\u0434\u043E\u0432
      \u0445\u0430\u0434\u0436\u0430."
    kazakhText: "\u049A\u0430\u0437\u0456\u0440 \u0441\u0456\u0437 \u049B\u0430\u0436\u044B\u043B\u044B\u049B\u0442\u044B\u04A3
      \u0435\u04A3 \u043C\u0430\u04A3\u044B\u0437\u0434\u044B \u0493\u0438\u0431\u0430\u0434\u0430\u0442\u044B 
      \u049A\u0430\u0493\u0431\u0430\u043D\u044B \u0432\u0438\u0440\u0442\u0443\u0430\u043B\u0434\u044B
      \u0444\u043E\u0440\u043C\u0430\u0442\u0442\u0430 \u0430\u0439\u043D\u0430\u043B\u0430\u0441\u044B\u0437."
    englishText: You are now about to perform Tawaf in virtual form, one of the most
      important rites of the Hajj.
    duration: 6
  - russianText: "\u0421\u0435\u043C\u0438\u043A\u0440\u0430\u0442\u043D\u044B\u0439
      \u043E\u0431\u0445\u043E\u0434 \u041A\u0430\u0430\u0431\u044B \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0430\u0435\u0442\u0441\u044F
      \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0439 \u043C\u043E\u043B\u0438\u0442\u0432\u043E\u0439,
      \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0435\u043C \u043A \u0412\u0441\u0435\u0432\u044B\u0448\u043D\u0435\u043C\u0443
      \u0438 \u043E\u0447\u0438\u0449\u0435\u043D\u0438\u0435\u043C \u0434\u0443\u0448\u0438."
    kazakhText: "\u049A\u0430\u0493\u0431\u0430\u043D\u044B \u0436\u0435\u0442\u0456
      \u0440\u0435\u0442 \u0430\u0439\u043D\u0430\u043B\u044B\u043F, \u0456\u0448\u0442\u0435\u0439
      \u0434\u04B1\u0493\u0430 \u049B\u044B\u043B\u0443, \u0442\u0456\u043B\u0435\u043A
      \u0442\u0456\u043B\u0435\u0443, \u0442\u0435\u043A \u049B\u0430\u043D\u0430
      \u049A\u04B1\u0434\u0430\u0439\u0434\u044B \u0435\u0441\u043A\u0435 \u0430\u043B\u0443
      \u049B\u0430\u0436\u0435\u0442."
    englishText: Circling the Kaaba seven times is accompanied by silent prayer,
      inner reflection, and remembrance of the Almighty.
    duration: 7
  - russianText: "\u0412 \u044D\u0442\u043E\u0442 \u043C\u0438\u0433 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
      \u0441\u043B\u043E\u0432\u043D\u043E \u0441\u043B\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u0441 \u0440\u0438\u0442\u043C\u043E\u043C \u0432\u0441\u0435\u0433\u043E
      \u043C\u0438\u0440\u043E\u0437\u0434\u0430\u043D\u0438\u044F, \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u043E\u0433\u043E
      \u0410\u043B\u043B\u0430\u0445\u043E\u043C,"
    kazakhText: "\u041A\u04AF\u043B\u043B\u0456 \u0436\u0430\u0440\u0430\u0442\u044B\u043B\u044B\u0441\u043F\u0435\u043D
      \u0431\u0456\u0440\u0433\u0435 \u0431\u0456\u0440 \u0442\u043E\u043B\u049B\u044B\u043D\u0434\u0430
      \u0436\u04AF\u0440\u0443 \u049A\u04B1\u0434\u0430\u0439 \u0422\u0430\u0493\u0430\u043B\u0430
      \u0436\u0430\u0440\u0430\u0442\u049B\u0430\u043D"
    englishText: In this moment, a person seems to merge with the rhythm of the entire
      universe created by Allah,
    duration: 4
  - russianText: "\u043E\u0449\u0443\u0449\u0430\u044F \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u043E
      \u0441 \u0432\u043E\u0441\u0435\u043C\u043D\u0430\u0434\u0446\u0430\u0442\u044C\u044E
      \u0442\u044B\u0441\u044F\u0447\u0430\u043C\u0438 \u043C\u0438\u0440\u043E\u0432
      \u0438 \u043F\u043E\u043A\u043E\u0440\u043D\u043E\u0441\u0442\u044C \u0432\u044B\u0441\u0448\u0435\u0439
      \u0431\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u0432\u043E\u043B\u0435."
    kazakhText: "18 \u043C\u044B\u04A3 \u0493\u0430\u043B\u0430\u043C\u043C\u0435\u043D
      \u0431\u0456\u0440 \u04BB\u04D9\u043C \u0410\u043B\u043B\u0430\u043D\u044B\u04A3
      \u04D9\u043C\u0456\u0440\u0456\u043D\u0435 \u043C\u043E\u0439\u044B\u043D\u0441\u044B\u043D\u0443\u0434\u044B
      \u0431\u0456\u043B\u0434\u0456\u0440\u0435\u0434\u0456."
    englishText: feeling unity with the eighteen thousand worlds and surrender to
      the Divine Will.
    duration: 5
  - russianText: "\u042D\u0442\u043E\u0442 \u043E\u0431\u0440\u044F\u0434 \u2014
      \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435
      \u043F\u043E \u043A\u0440\u0443\u0433\u0443. \u041F\u043E\u0434\u043E\u0431\u043D\u043E
      \u0442\u043E\u043C\u0443 \u043A\u0430\u043A \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u044B
      \u0432\u0440\u0430\u0449\u0430\u044E\u0442\u0441\u044F \u0432\u043E\u043A\u0440\u0443\u0433
      \u044F\u0434\u0440\u0430,"
    kazakhText: "\u0411\u04B1\u043B \u0440\u04D9\u0441\u0456\u043C \u0436\u0430\u0439
      \u049B\u043E\u0437\u0493\u0430\u043B\u044B\u0441 \u0435\u043C\u0435\u0441,
      \u0430\u0442\u043E\u043C \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u0434\u0430\u0440\u044B\u043D\u044B\u04A3
      \u044F\u0434\u0440\u043E\u043D\u044B \u0430\u0439\u043D\u0430\u043B\u0493\u0430\u043D\u044B\u043D\u0434\u0430\u0439,"
    englishText: This ritual is not merely movement in a circle. Just as electrons
      revolve around a nucleus,
    duration: 5
  - russianText: "\u0417\u0435\u043C\u043B\u044F \u2014 \u0432\u043E\u043A\u0440\u0443\u0433
      \u0421\u043E\u043B\u043D\u0446\u0430, \u0430 \u043F\u043B\u0430\u043D\u0435\u0442\u044B
      \u0434\u0432\u0438\u0436\u0443\u0442\u0441\u044F \u0432 \u0435\u0434\u0438\u043D\u043E\u043C
      \u043A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u043C \u0440\u0438\u0442\u043C\u0435,
      \u0442\u0430\u0432\u0430\u0444 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
      \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C "
    kazakhText: "\u0416\u0435\u0440\u0434\u0456\u04A3 \u041A\u04AF\u043D\u0434\u0456,
      \u041A\u04AF\u043D\u043D\u0456\u04A3 \u04E9\u0437\u0433\u0435 \u0493\u0430\u043B\u0430\u043C\u0448\u0430\u0440\u043B\u0430\u0440\u0434\u044B,
      \u0442\u04AF\u043F\u0442\u0435\u043F \u043A\u0435\u043B\u0433\u0435\u043D\u0434\u0435
      \u043A\u04AF\u043B\u043B\u0456 \u0436\u0430\u0440\u0430\u0442\u044B\u043B\u044B\u0441\u0442\u044B\u04A3
      \u0431\u0456\u0440 \u0431\u0430\u0493\u044B\u0442\u0442\u0430,"
    englishText: the Earth around the Sun, and the planets move within one cosmic
      rhythm, Tawaf becomes a symbol
    duration: 7
  - russianText: "\u0432\u0441\u0435\u043E\u0431\u0449\u0435\u0433\u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0430,
      \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0438 \u0438 \u0432\u0435\u0447\u043D\u043E\u0433\u043E
      \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0432\u0441\u0435\u0433\u043E
      \u0441\u0443\u0449\u0435\u0433\u043E \u043A \u0421\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044E."
    kazakhText: "\u0431\u0456\u0440 \u044B\u0440\u0493\u0430\u049B\u0442\u0430 \u049B\u043E\u0437\u0493\u0430\u043B\u0430\u0442\u044B\u043D\u044B\u043D
      \u0431\u0456\u043B\u0434\u0456\u0440\u0435\u0442\u0456\u043D \u0431\u0456\u0440\u043B\u0456\u043A
      \u0438\u0448\u0430\u0440\u0430\u0441\u044B, \u0431\u0456\u0440\u0456\u0433\u0443
      \u0493\u0438\u0431\u0430\u0434\u0430\u0442\u044B."
    englishText: of universal unity, harmony, and the eternal movement of all creation
      toward the Creator.
    duration: 5
