MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "5 \u041E\u0434\u0435\u0441\u0441\u0430 \u041C\u043E\u0434\u0443\u043B\u044C
    3"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - firstLanguageText: "\u0418\u0437 \u041E\u0434\u0435\u0441\u0441\u044B \u0428\u0430\u043A\u0430\u0440\u0438\u043C
      \u041A\u0443\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0438\u0435\u0432 \u0441\u0430\u0434\u0438\u0442\u0441\u044F
      \u043D\u0430 \u043F\u0430\u0440\u043E\u0445\u043E\u0434"
    secondLanguageText: From Odessa, Shakarim Qudaiberdiuly boarded a steamship
    duration: 3
  - firstLanguageText: "\u0438 \u043F\u0440\u0438\u0431\u044B\u0432\u0430\u0435\u0442
      \u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0421\u0442\u0430\u043C\u0431\u0443\u043B
      - \u0441\u0442\u043E\u043B\u0438\u0446\u0443 \u041E\u0441\u043C\u0430\u043D\u0441\u043A\u043E\u0439
      \u0438\u043C\u043F\u0435\u0440\u0438\u0438."
    secondLanguageText: and arrived in the legendary city of Istanbul - the capital
      of the Ottoman Empire.
    duration: 5
  - firstLanguageText: "\u0414\u043B\u044F \u043A\u0430\u0437\u0430\u0445\u0441\u043A\u0438\u0445
      \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A\u043E\u0432 \u0421\u0442\u0430\u043C\u0431\u0443\u043B
      \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0440\u0430\u043D\u0437\u0438\u0442\u043D\u044B\u043C
      \u0433\u043E\u0440\u043E\u0434\u043E\u043C,"
    secondLanguageText: For Kazakh pilgrims, Istanbul was not merely a transit city,
    duration: 3
  - firstLanguageText: "\u0430 \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u0445
      \u0446\u0435\u043D\u0442\u0440\u043E\u0432 \u0438\u0441\u043B\u0430\u043C\u0441\u043A\u043E\u0439
      \u0446\u0438\u0432\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0438\u2026"
    secondLanguageText: "but one of the great spiritual centers of Islamic civilization\u2026"
    duration: 3
  - firstLanguageText: "\u0418\u043C\u0435\u043D\u043D\u043E \u0437\u0434\u0435\u0441\u044C
      \u043F\u0435\u0440\u0435\u0434 \u043F\u043E\u044D\u0442\u043E\u043C \u0441\u043B\u043E\u0432\u043D\u043E
      \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442 "
    secondLanguageText: Here, before the poet,
    duration: 3
  - firstLanguageText: "\u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u0442\u044C\u0441\u044F
      \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u043C\u0438\u0440
      \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0445 \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u0435\u0439
      \u0438 \u043F\u043E\u044D\u0442\u043E\u0432,"
    secondLanguageText: the wondrous world of the Eastern thinkers and poets
    duration: 3
  - firstLanguageText: "\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043E\u043D \u043F\u043E\u0447\u0438\u0442\u0430\u043B
      \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C: \u0425\u043E\u0434\u0436\u0438
      \u0425\u0430\u0444\u0438\u0437\u0430, \u041D\u0430\u0432\u043E\u0438, \u0424\u0438\u0440\u0434\u043E\u0443\u0441\u0438,
      \u041D\u0438\u0437\u0430\u043C\u0438, \u0420\u0443\u043C\u0438\u2026"
    secondLanguageText: "he revered throughout his life seemed to unfold \u2014 Hafez,
      Navoi, Ferdowsi, Nizami, Rumi\u2026"
    duration: 6
  - firstLanguageText: "\u041E \u0441\u0432\u043E\u0451\u043C \u043F\u0440\u0435\u0431\u044B\u0432\u0430\u043D\u0438\u0438
      \u0432 \u0421\u0442\u0430\u043C\u0431\u0443\u043B\u0435 \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A
      \u043F\u0438\u0441\u0430\u043B:"
    secondLanguageText: 'Of his days in Istanbul, the pilgrim wrote:'
    duration: 2
  - firstLanguageText: "\xAB\u041C\u0435\u0441\u044F\u0446 \u043F\u043B\u044B\u043B
      \u044F \u043D\u0430 \u043F\u0430\u0440\u043E\u0445\u043E\u0434\u0435 \u0432
      \u0434\u043E\u0440\u043E\u0433\u0435,"
    secondLanguageText: "\u201CFor a month I sailed upon the steamer,"
    duration: 2
  - firstLanguageText: "\u0412\u0441\u0442\u0440\u0435\u0447\u0430\u044F \u0432 \u0440\u0430\u0437\u043D\u044B\u0445
      \u0441\u0442\u0440\u0430\u043D\u0430\u0445 \u043C\u0443\u043B\u043B \u0438
      \u0443\u0447\u0451\u043D\u044B\u0445."
    secondLanguageText: Meeting scholars and mullahs in many lands.
    duration: 2
  - firstLanguageText: "\u0422\u0440\u0438\u043D\u0430\u0434\u0446\u0430\u0442\u044C
      \u0434\u043D\u0435\u0439 \u043F\u0440\u043E\u0432\u0451\u043B \u0432 \u0421\u0442\u0430\u043C\u0431\u0443\u043B\u0435"
    secondLanguageText: Thirteen days I spent in Istanbul
    duration: 2
  - firstLanguageText: "\u0418 \u043D\u0430\u0448\u0451\u043B \u043A\u043D\u0438\u0433\u0438,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u043A\u0430\u043B."
    secondLanguageText: And there I found the books I sought.
    duration: 2
  - firstLanguageText: "\u041B\u044E\u0434\u0438, \u043E\u0431\u0443\u0447\u0430\u0432\u0448\u0438\u0435\u0441\u044F
      \u0434\u0430\u0436\u0435 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435,"
    secondLanguageText: Men educated even in Paris,
    duration: 3
  - firstLanguageText: "\u0422\u0443\u0440\u043A\u0438, \u0447\u0435\u0440\u043A\u0435\u0441\u044B
      \u0438 \u0438\u043D\u0434\u0438\u0439\u0446\u044B,"
    secondLanguageText: Turks, Circassians, and Indians,
    duration: 2
  - firstLanguageText: "\u0410\u0440\u0430\u0431\u044B, \u0431\u0430\u0448\u043A\u0438\u0440\u044B,
      \u043A\u044B\u0437\u044B\u043B\u0431\u0430\u0448\u0438 "
    secondLanguageText: Arabs, Bashkirs, and Qizilbash
    duration: 2
  - firstLanguageText: "\u041F\u0435\u0440\u0435\u0432\u043E\u0434\u0447\u0438\u043A\u043E\u043C
      \u0431\u044B\u043B \u0442\u0443\u0440\u043E\u043A-\u043D\u043E\u0433\u0430\u0439."
    secondLanguageText: A Turkish Nogai served as translator.
    duration: 2
  - firstLanguageText: "\u0411\u0435\u0441\u0435\u0434\u0443\u044F \u0441 \u043D\u0438\u043C\u0438,"
    secondLanguageText: Speaking with them,
    duration: 2
  - firstLanguageText: "\u042F \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F
      \u043A \u0438\u043D\u043E\u0439, \u0432\u044B\u0441\u043E\u043A\u043E\u0439
      \u0446\u0435\u043B\u0438."
    secondLanguageText: I pursued a higher purpose.
    duration: 2
  - firstLanguageText: "\u0411\u0443\u0434\u0442\u043E \u043B\u0443\u0447 \u0441\u0432\u0435\u0442\u0430
      \u0443\u043F\u0430\u043B"
    secondLanguageText: It was as though a beam of light
    duration: 1
  - firstLanguageText: "\u041D\u0430 \u043E\u0441\u043B\u0435\u043F\u043B\u0451\u043D\u043D\u044B\u0435
      \u0433\u043B\u0430\u0437\u0430,"
    secondLanguageText: Fell upon blinded eyes,
    duration: 2
  - firstLanguageText: "\u0418 \u0442\u044F\u0436\u0451\u043B\u044B\u0439 \u0442\u0443\u043C\u0430\u043D
      \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0441\u0441\u0435\u0438\u0432\u0430\u0442\u044C\u0441\u044F\u2026"
    secondLanguageText: "And the heavy mist began to lift\u2026"
    duration: 2
  - firstLanguageText: "\u0414\u043B\u044F \u044D\u0442\u0438\u0445 \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439"
    secondLanguageText: For such reflections,
    duration: 1
  - firstLanguageText: "\u041D\u0443\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u043C\u043D\u043E\u0433\u043E\u0435
      \u043F\u043E\u043D\u044F\u0442\u044C,"
    secondLanguageText: 'Much understanding was required:'
    duration: 1
  - firstLanguageText: "\u0421\u043E\u0431\u0440\u0430\u0442\u044C \u0441\u043B\u043E\u0432\u0430\u0440\u0438
      \u0440\u0430\u0437\u043D\u044B\u0445 \u044F\u0437\u044B\u043A\u043E\u0432,"
    secondLanguageText: To gather dictionaries of many tongues,
    duration: 2
  - firstLanguageText: "\u041F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C \u0432\u0441\u0451
      \u0440\u0430\u0437\u0443\u043C\u043E\u043C"
    secondLanguageText: To test all things through reason,
    duration: 2
  - firstLanguageText: "\u0418 \u043F\u043E\u0432\u0435\u0440\u0438\u0442\u044C \u043B\u0438\u0448\u044C
      \u0438\u0441\u0442\u0438\u043D\u0435\u2026"
    secondLanguageText: "And believe only in truth\u2026"
    duration: 2
  - firstLanguageText: "\u0414\u043B\u044F \u043D\u0435\u0432\u0435\u0436\u0434\u044B
      \u044D\u0442\u043E \u0431\u044B\u043B\u043E \u043D\u0435\u043B\u0435\u0433\u043A\u043E\u2026\xBB"
    secondLanguageText: "For the ignorant, this was no easy path\u2026"
    duration: 2
