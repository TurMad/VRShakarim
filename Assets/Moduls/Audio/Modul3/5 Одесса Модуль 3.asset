--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "5 \u041E\u0434\u0435\u0441\u0441\u0430 \u041C\u043E\u0434\u0443\u043B\u044C
    3"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0418\u0437 \u041E\u0434\u0435\u0441\u0441\u044B \u0428\u0430\u043A\u0430\u0440\u0438\u043C
      \u041A\u0443\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0438\u0435\u0432 \u0441\u0430\u0434\u0438\u0442\u0441\u044F
      \u043D\u0430 \u043F\u0430\u0440\u043E\u0445\u043E\u0434"
    kazakhText: "\u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456\u04B1\u043B\u044B
      \u041E\u0434\u0435\u0441\u0441\u0430\u0434\u0430\u043D \u043F\u0430\u0440\u043E\u0445\u043E\u0434\u049B\u0430
      \u043E\u0442\u044B\u0440\u044B\u043F,"
    englishText: From Odessa, Shakarim Qudaiberdiuly boarded a steamship
    duration: 3
  - russianText: "\u0438 \u043F\u0440\u0438\u0431\u044B\u0432\u0430\u0435\u0442 \u0432
      \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0421\u0442\u0430\u043C\u0431\u0443\u043B
      \u2014 \u0441\u0442\u043E\u043B\u0438\u0446\u0443 \u041E\u0441\u043C\u0430\u043D\u0441\u043A\u043E\u0439
      \u0438\u043C\u043F\u0435\u0440\u0438\u0438."
    kazakhText: "\u041E\u0441\u043C\u0430\u043D \u0438\u043C\u043F\u0435\u0440\u0438\u044F\u0441\u044B\u043D\u044B\u04A3
      \u0430\u0441\u0442\u0430\u043D\u0430\u0441\u044B \u0431\u043E\u043B\u0493\u0430\u043D
      \u0430\u0442\u0430\u049B\u0442\u044B \u042B\u0441\u0442\u0430\u043C\u0431\u043E\u043B
      \u049B\u0430\u043B\u0430\u0441\u044B\u043D\u0430 \u043A\u0435\u043B\u0435\u0434\u0456."
    englishText: "and arrived in the legendary city of Istanbul \u2014 the capital
      of the Ottoman Empire."
    duration: 5
  - russianText: "\u0414\u043B\u044F \u043A\u0430\u0437\u0430\u0445\u0441\u043A\u0438\u0445
      \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A\u043E\u0432 \u0421\u0442\u0430\u043C\u0431\u0443\u043B
      \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0440\u0430\u043D\u0437\u0438\u0442\u043D\u044B\u043C
      \u0433\u043E\u0440\u043E\u0434\u043E\u043C,"
    kazakhText: "\u0421\u0442\u0430\u043C\u0431\u0443\u043B \u049B\u0430\u0437\u0430\u049B
      \u049B\u0430\u0436\u044B\u043B\u0430\u0440\u044B \u04AF\u0448\u0456\u043D \u0442\u0435\u043A
      \u0442\u0440\u0430\u043D\u0437\u0438\u0442\u0442\u0456\u043A \u049B\u0430\u043B\u0430
      \u0435\u043C\u0435\u0441,"
    englishText: For Kazakh pilgrims, Istanbul was not merely a transit city,
    duration: 3
  - russianText: "\u0430 \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u0445
      \u0446\u0435\u043D\u0442\u0440\u043E\u0432 \u0438\u0441\u043B\u0430\u043C\u0441\u043A\u043E\u0439
      \u0446\u0438\u0432\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0438\u2026"
    kazakhText: "\u0438\u0441\u043B\u0430\u043C \u04E9\u0440\u043A\u0435\u043D\u0438\u0435\u0442\u0456\u043D\u0456\u04A3
      \u043E\u0440\u0442\u0430\u043B\u044B\u0493\u044B \u0435\u0434\u0456..."
    englishText: "but one of the great spiritual centers of Islamic civilization\u2026"
    duration: 3
  - russianText: "\u0418\u043C\u0435\u043D\u043D\u043E \u0437\u0434\u0435\u0441\u044C
      \u043F\u0435\u0440\u0435\u0434 \u043F\u043E\u044D\u0442\u043E\u043C \u0441\u043B\u043E\u0432\u043D\u043E
      \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442 \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u0442\u044C\u0441\u044F "
    kazakhText: "\u0415\u043D\u0434\u0456\u0433\u0456 \u043C\u0435\u0437\u0435\u0442\u0442\u0435
      \u0430\u049B\u044B\u043D\u043D\u044B\u04A3 \u04E9\u0437\u0456 \u043F\u0456\u0440
      \u0442\u04B1\u0442\u049B\u0430\u043D \u04D9\u0439\u0433\u0456\u043B\u0456"
    englishText: Here, before the poet, the wondrous world of the Eastern thinkers
    duration: 3
  - russianText: "\u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
      \u043C\u0438\u0440 \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0445 \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u0435\u0439
      \u0438 \u043F\u043E\u044D\u0442\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0445
      \u043E\u043D \u043F\u043E\u0447\u0438\u0442\u0430\u043B \u0432\u0441\u044E
      \u0436\u0438\u0437\u043D\u044C:"
    kazakhText: "\u049A\u043E\u0436\u0430 \u0425\u0430\u0444\u0438\u0437, \u041D\u0430\u0443\u0430\u0438,
      \u0424\u0438\u0440\u0434\u043E\u0443\u0441\u0438, \u041D\u0438\u0437\u0430\u043C\u0438,
      \u0420\u0443\u043C\u0438"
    englishText: and poets he revered throughout his life seemed to unfold
    duration: 5
  - russianText: "\u0425\u043E\u0434\u0436\u0438 \u0425\u0430\u0444\u0438\u0437\u0430,
      \u041D\u0430\u0432\u043E\u0438, \u0424\u0438\u0440\u0434\u043E\u0443\u0441\u0438,
      \u041D\u0438\u0437\u0430\u043C\u0438, \u0420\u0443\u043C\u0438\u2026"
    kazakhText: "\u0441\u044B\u043D\u0434\u044B \u0448\u044B\u0493\u044B\u0441 \u0448\u0430\u0439\u044B\u0440\u043B\u0430\u0440\u044B\u043D\u044B\u04A3
      \u0493\u0430\u0436\u0430\u0439\u044B\u043F  \u04D9\u043B\u0435\u043C\u0456
      \u0441\u044B\u0440 \u0448\u0435\u0440\u0442\u0435 \u0431\u0430\u0441\u0442\u0430\u0439\u0434\u044B..."
    englishText: "Hafez, Navoi, Ferdowsi, Nizami, Rumi\u2026"
    duration: 4
  - russianText: "\u041E \u0441\u0432\u043E\u0451\u043C \u043F\u0440\u0435\u0431\u044B\u0432\u0430\u043D\u0438\u0438
      \u0432 \u0421\u0442\u0430\u043C\u0431\u0443\u043B\u0435 \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A
      \u043F\u0438\u0441\u0430\u043B:"
    kazakhText: "\u0411\u04B1\u043B \u0436\u04E9\u043D\u0456\u043D\u0434\u0435 \u049B\u0430\u0436\u044B
      \u04E9\u0437 \u04E9\u043B\u0435\u04A3\u0456\u043D\u0434\u0435: "
    englishText: 'Of his days in Istanbul, the pilgrim wrote:'
    duration: 2
  - russianText: "\xAB\u041C\u0435\u0441\u044F\u0446 \u043F\u043B\u044B\u043B \u044F
      \u043D\u0430 \u043F\u0430\u0440\u043E\u0445\u043E\u0434\u0435 \u0432 \u0434\u043E\u0440\u043E\u0433\u0435,"
    kazakhText: "\u041F\u0430\u0440\u043E\u0445\u043E\u0434\u043F\u0435\u043D \u0430\u0439
      \u0436\u04AF\u0440i\u043F \u0436\u043E\u043B\u0434\u0430,"
    englishText: "\u201CFor a month I sailed upon the steamer,"
    duration: 2
  - russianText: "\u0412\u0441\u0442\u0440\u0435\u0447\u0430\u044F \u0432 \u0440\u0430\u0437\u043D\u044B\u0445
      \u0441\u0442\u0440\u0430\u043D\u0430\u0445 \u043C\u0443\u043B\u043B \u0438
      \u0443\u0447\u0451\u043D\u044B\u0445."
    kazakhText: "\u04D8\u0440 \u0435\u043B\u0434\u0435 \u043A\u0435\u0437 \u043A\u0435\u043Bi\u043F
      \u043C\u043E\u043B\u0434\u0430,"
    englishText: Meeting scholars and mullahs in many lands.
    duration: 3
  - russianText: "\u0422\u0440\u0438\u043D\u0430\u0434\u0446\u0430\u0442\u044C \u0434\u043D\u0435\u0439
      \u043F\u0440\u043E\u0432\u0451\u043B \u0432 \u0421\u0442\u0430\u043C\u0431\u0443\u043B\u0435"
    kazakhText: "\u041E\u043D \u04AF\u0448 \u043A\u04AF\u043D \u0431\u043E\u043F
      \u0421\u0442\u0430\u043C\u0431\u043E\u043B\u0434\u0430,"
    englishText: Thirteen days I spent in Istanbul
    duration: 2
  - russianText: "\u0418 \u043D\u0430\u0448\u0451\u043B \u043A\u043D\u0438\u0433\u0438,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u043A\u0430\u043B."
    kazakhText: "\u041A\u0435\u0440\u0435\u043A \u043Ai\u0442\u0430\u043F \u0442\u0430\u0431\u044B\u043B\u0493\u0430\u043D\u044B-\u0430\u0439!"
    englishText: And there I found the books I sought.
    duration: 2
  - russianText: "\u041B\u044E\u0434\u0438, \u043E\u0431\u0443\u0447\u0430\u0432\u0448\u0438\u0435\u0441\u044F
      \u0434\u0430\u0436\u0435 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435,"
    kazakhText: "\u041F\u0430\u0440\u0438\u0436\u0434\u0435 \u0434\u0435 \u043E\u049B\u044B\u0493\u0430\u043D
      \u0436\u0430\u043D,"
    englishText: Men educated even in Paris,
    duration: 2
  - russianText: "\u0422\u0443\u0440\u043A\u0438, \u0447\u0435\u0440\u043A\u0435\u0441\u044B
      \u0438 \u0438\u043D\u0434\u0438\u0439\u0446\u044B,"
    kazakhText: "\u0422\u04AF\u0440i\u043A, \u0441\u0435\u0440\u043A\u0435\u0448
      \u04D9\u043C \u04AE\u043D\u0434i\u0441\u0442\u0430\u043D,"
    englishText: Turks, Circassians, and Indians,
    duration: 2
  - russianText: "\u0410\u0440\u0430\u0431\u044B, \u0431\u0430\u0448\u043A\u0438\u0440\u044B,
      \u043A\u044B\u0437\u044B\u043B\u0431\u0430\u0448\u0438"
    kazakhText: "\u0410\u0440\u0430\u0431, \u0431\u0430\u0448\u049B\u04B1\u0440\u0442,
      \u049B\u044B\u0437\u044B\u043B\u0431\u0430\u0441\u0442\u0430\u043D,"
    englishText: Arabs, Bashkirs, and Qizilbash
    duration: 2
  - russianText: "\u041F\u0435\u0440\u0435\u0432\u043E\u0434\u0447\u0438\u043A\u043E\u043C
      \u0431\u044B\u043B \u0442\u0443\u0440\u043E\u043A-\u043D\u043E\u0433\u0430\u0439."
    kazakhText: "\u041F\u0435\u0440\u0435\u0432\u043E\u0434\u0447\u0438\u043A \u2013
      \u0442\u04AF\u0440i\u043A, \u043D\u043E\u0493\u0430\u0439."
    englishText: A Turkish Nogai served as translator.
    duration: 2
  - russianText: "\u0411\u0435\u0441\u0435\u0434\u0443\u044F \u0441 \u043D\u0438\u043C\u0438,"
    kazakhText: "\u0421\u043E\u043B\u0430\u0440\u043C\u0435\u043D \u043Ai\u0440i\u0441i\u043F
      \u0441\u04E9\u0437\u0433\u0435,"
    englishText: Speaking with them,
    duration: 2
  - russianText: "\u042F \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F \u043A
      \u0438\u043D\u043E\u0439, \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0446\u0435\u043B\u0438."
    kazakhText: "\u0416\u043E\u0493\u0430\u0440\u0493\u044B \u043E\u0439-\u043C\u0430\u049B\u0441\u0430\u0442\u044B\u043C
      \u04E9\u0437\u0433\u0435,"
    englishText: I pursued a higher purpose.
    duration: 2
  - russianText: "\u0411\u0443\u0434\u0442\u043E \u043B\u0443\u0447 \u0441\u0432\u0435\u0442\u0430
      \u0443\u043F\u0430\u043B \u043D\u0430 \u043E\u0441\u043B\u0435\u043F\u043B\u0451\u043D\u043D\u044B\u0435
      \u0433\u043B\u0430\u0437\u0430,"
    kazakhText: "\u0422\u04AF\u0441i\u043F \u0441\u04D9\u0443\u043B\u0435 \u0441\u043E\u049B\u044B\u0440
      \u043A\u04E9\u0437\u0433\u0435,"
    englishText: It was as though a beam of light fell upon blinded eyes,
    duration: 2
  - russianText: "\u0418 \u0442\u044F\u0436\u0451\u043B\u044B\u0439 \u0442\u0443\u043C\u0430\u043D
      \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0441\u0441\u0435\u0438\u0432\u0430\u0442\u044C\u0441\u044F\u2026"
    kazakhText: "\u0410\u0443\u044B\u0440 \u0442\u04B1\u043C\u0430\u043D \u0430\u0448\u044B\u043B\u0443\u044B-\u0430\u0439!"
    englishText: "And the heavy mist began to lift\u2026"
    duration: 3
  - russianText: "\u0414\u043B\u044F \u044D\u0442\u0438\u0445 \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439
      \u041D\u0443\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u043C\u043D\u043E\u0433\u043E\u0435
      \u043F\u043E\u043D\u044F\u0442\u044C,"
    kazakhText: "\u041E\u043B \u043E\u0439\u0493\u0430 \u043A\u04E9\u043F \u043A\u0435\u0440\u0435\u043A
      \u0442\u0430\u0440\u043C\u0430\u049B,"
    englishText: 'For such reflections, Much understanding was required:'
    duration: 2
  - russianText: "\u0421\u043E\u0431\u0440\u0430\u0442\u044C \u0441\u043B\u043E\u0432\u0430\u0440\u0438
      \u0440\u0430\u0437\u043D\u044B\u0445 \u044F\u0437\u044B\u043A\u043E\u0432,"
    kazakhText: "\u04D8\u0440 \u0442i\u043B\u0434\u0435\u043D \u0441\u043B\u043E\u0432\u0430\u0440\u044C
      \u0430\u043B\u043C\u0430\u049B."
    englishText: To gather dictionaries of many tongues,
    duration: 2
  - russianText: "\u041F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C \u0432\u0441\u0451
      \u0440\u0430\u0437\u0443\u043C\u043E\u043C "
    kazakhText: "\u0421\u044B\u043D\u0430\u043F \u043D\u0430\u0493\u044B\u0437\u044B\u043D\u0430
      \u043D\u0430\u043D\u0431\u0430\u049B"
    englishText: To test all things through reason,
    duration: 2
  - russianText: "\u0418 \u043F\u043E\u0432\u0435\u0440\u0438\u0442\u044C \u043B\u0438\u0448\u044C
      \u0438\u0441\u0442\u0438\u043D\u0435\u2026 \u0414\u043B\u044F \u043D\u0435\u0432\u0435\u0436\u0434\u044B
      \u044D\u0442\u043E \u0431\u044B\u043B\u043E \u043D\u0435\u043B\u0435\u0433\u043A\u043E\u2026\xBB"
    kazakhText: "\u041D\u0430\u0434\u0430\u043D\u0493\u0430 \u0431\u043E\u043B\u043C\u0430\u0434\u044B-\u0430\u0443
      \u043E\u04A3\u0430\u0439!- \u0434\u0435\u043F \u0436\u044B\u0440\u043B\u0430\u0439\u0434\u044B."
    englishText: "And believe only in truth\u2026 For the ignorant, this was no easy
      path\u2026\u201D"
    duration: 4
