MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "2 \u0421\u0435\u043C\u0435\u0438\u0306  \u0422\u044B\u043D\u044B\u0431\u0430\u0438\u0306
    \u043C\u0435\u0448\u0456\u0442\u0456 \u041C\u043E\u0434\u0443\u043B\u044C 3"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u041F\u0430\u043B\u043E\u043C\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0435
      \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0428\u0430\u043A\u0430\u0440\u0438\u043C
      \u041A\u0443\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0438\u0435\u0432 \u043D\u0430\u0447\u0430\u043B\u043E\u0441\u044C
      \u0432 \u043D\u043E\u044F\u0431\u0440\u0435 1905 \u0433\u043E\u0434\u0430 \u0438\u0437
      \u0433\u043E\u0440\u043E\u0434\u0430 \u0421\u0435\u043C\u0435\u0439."
    kazakhText: "\u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456\u04B1\u043B\u044B\u043D\u044B\u04A3
      \u049B\u0430\u0436\u044B\u043B\u044B\u049B \u0441\u0430\u043F\u0430\u0440\u044B
      1905 \u0436\u044B\u043B\u044B \u049B\u0430\u0440\u0430\u0448\u0430 \u0430\u0439\u044B\u043D\u0434\u0430
      \u0421\u0435\u043C\u0435\u0439 \u049B\u0430\u043B\u0430\u0441\u044B\u043D\u0430\u043D
      \u0431\u0430\u0441\u0442\u0430\u043B\u0434\u044B."
    englishText: The pilgrimage journey of Shakarim Qudaiberdiuly began in November
      1905 from the city of Semey.
    duration: 8
  - russianText: "\xAB\u0412 \u0445\u0430\u0434\u0436 \u0442\u0430\u043A\u0436\u0435
      \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0438\u0441\u044C \u041A\u0443\u0440\u043C\u0430\u043D\u043A\u043E\u0436\u0430
      \u041A\u0443\u0434\u0435\u043D\u043E\u0432, \u041A\u0443\u0440\u0435\u043D\u0448\u0438
      \u0428\u043E\u043A\u0438\u043D"
    kazakhText: "\xAB\u049A\u0430\u0436\u044B\u043B\u044B\u049B\u049B\u0430 \u0411\u04E9\u0440\u043B\u0456
      \u043C\u0435\u043D \u0428\u0430\u0493\u0430\u043D \u0431\u043E\u043B\u044B\u0441\u044B\u043D\u0430\u043D
      \u049A\u04B1\u0440\u043C\u0430\u043D\u049B\u043E\u0436\u0430 \u041A\u04AF\u0434\u0435\u043D\u043E\u0432,"
    englishText: "\u201CKurmankozha Kudenov, Kurenshi Shokin, and Qutan Zholzhasarov"
    duration: 4
  - russianText: "\u0438 \u049A\u04B1\u0442\u0430\u043D \u0416\u043E\u043B\u0436\u0430\u0441\u0430\u0440\u043E\u0432
      \u0438\u0437 \u0411\u0451\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439 \u0438
      \u0428\u0430\u0433\u0430\u043D\u0441\u043A\u043E\u0439 \u0432\u043E\u043B\u043E\u0441\u0442\u0435\u0439\xBB."
    kazakhText: "\u041A\u04AF\u0440\u0435\u04A3\u0448\u0456 \u0428\u043E\u049B\u0438\u043D,
      \u049A\u04B1\u0442\u0430\u043D \u0416\u043E\u043B\u0436\u0430\u0441\u0430\u0440\u043E\u0432
      \u0442\u0430 \u0431\u0430\u0440\u0493\u0430\u043D\xBB."
    englishText: "from the Borly and Shagan districts also departed for the Hajj.\u201D"
    duration: 4
  - russianText: "\u041F\u0443\u0442\u043D\u0438\u043A\u0438 \u043D\u0430 \u043F\u0430\u0440\u043E\u0445\u043E\u0434\u0435
      \u043F\u0440\u043E\u0448\u043B\u0438 \u043F\u043E \u0418\u0440\u0442\u044B\u0448\u0443
      \u0434\u043E \u041E\u043C\u0441\u043A\u0430."
    kazakhText: "\u0416\u043E\u043B\u0430\u0443\u0448\u044B\u043B\u0430\u0440 \u0415\u0440\u0442\u0456\u0441
      \u04E9\u0437\u0435\u043D\u0456 \u0430\u0440\u049B\u044B\u043B\u044B \u043F\u0430\u0440\u043E\u0445\u043E\u0434\u043F\u0435\u043D
      \u041E\u043C\u0431\u044B\u0493\u0430 \u0434\u0435\u0439\u0456\u043D \u0436\u0435\u0442\u0442\u0456."
    englishText: The travelers journeyed by steamboat along the Irtysh River to Omsk.
    duration: 4
  - russianText: "\u0412 \u0442\u0443 \u044D\u043F\u043E\u0445\u0443 \u0440\u0435\u0447\u043D\u043E\u0439
      \u0442\u0440\u0430\u043D\u0441\u043F\u043E\u0440\u0442 \u0431\u044B\u043B \u0441\u0430\u043C\u044B\u043C
      \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u043C"
    kazakhText: "\u0421\u043E\u043B \u043A\u0435\u0437\u0435\u04A3\u0434\u0435 \u04E9\u0437\u0435\u043D
      \u043A\u04E9\u043B\u0456\u0433\u0456 \u0421\u0456\u0431\u0456\u0440 \u043C\u0435\u043D
      \u0414\u0430\u043B\u0430 \u04E9\u043B\u043A\u0435\u0441\u0456 \u04AF\u0448\u0456\u043D"
    englishText: At that time, river transport was considered the safest
    duration: 4
  - russianText: "\u0438 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u044B\u043C
      \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u043C \u043F\u0435\u0440\u0435\u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
      \u0434\u043B\u044F \u0421\u0438\u0431\u0438\u0440\u0438 \u0438 \u0421\u0442\u0435\u043F\u043D\u043E\u0433\u043E
      \u043A\u0440\u0430\u044F."
    kazakhText: "\u0435\u04A3 \u049B\u043E\u043B\u0436\u0435\u0442\u0456\u043C\u0434\u0456
      \u0436\u04D9\u043D\u0435 \u049B\u0430\u0443\u0456\u043F\u0441\u0456\u0437 \u049B\u043E\u0437\u0493\u0430\u043B\u044B\u0441
      \u0442\u04AF\u0440\u0456 \u0435\u0434\u0456."
    englishText: and most accessible means of travel across Siberia and the Great
      Steppe.
    duration: 4
  - russianText: "\u0412 \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u043C
      \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
      \u0430\u0440\u0445\u0438\u0432\u0435 \u0420\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0438
      \u041A\u0430\u0437\u0430\u0445\u0441\u0442\u0430\u043D"
    kazakhText: "\xAB\u049A\u0430\u0437\u0430\u049B\u0441\u0442\u0430\u043D \u0420\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0441\u044B\u043D\u044B\u04A3
      \u041E\u0440\u0442\u0430\u043B\u044B\u049B \u043C\u0435\u043C\u043B\u0435\u043A\u0435\u0442\u0442\u0456\u043A
      \u043C\u04B1\u0440\u0430\u0493\u0430\u0442\u044B\u043D\u0434\u0430"
    englishText: Documents of pilgrims who journeyed to Mecca have been preserved
    duration: 4
  - russianText: "\u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C
      \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A\u043E\u0432,
      \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u0432\u0448\u0438\u0445 \u0445\u0430\u0434\u0436
      \u0432 \u041C\u0435\u043A\u043A\u0443."
    kazakhText: "\u041C\u0435\u043A\u043A\u0435\u0433\u0435 \u049B\u0430\u0436\u044B\u043B\u044B\u049B\u049B\u0430
      \u0431\u0430\u0440\u0493\u0430\u043D \u049B\u0430\u0436\u044B\u043B\u0430\u0440\u0434\u044B\u04A3
      \u049B\u04B1\u0436\u0430\u0442\u0442\u0430\u0440\u044B \u0441\u0430\u049B\u0442\u0430\u043B\u0493\u0430\u043D."
    englishText: in the Central State Archive of the Republic of Kazakhstan.
    duration: 4
  - russianText: "\u0412 \u0441\u043F\u0438\u0441\u043A\u0435 \u043A\u0430\u0437\u0430\u0445\u0441\u043A\u0438\u0445
      \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A\u043E\u0432 \u0437\u0430 1905
      \u0433\u043E\u0434 \u0428\u0430\u043A\u0430\u0440\u0438\u043C-\u0445\u0430\u0434\u0436\u0438
      \u0437\u043D\u0430\u0447\u0438\u0442\u0441\u044F \u043F\u043E\u0434 \u043D\u043E\u043C\u0435\u0440\u043E\u043C
      221 \u043A\u0430\u043A:"
    kazakhText: "1905 \u0436\u044B\u043B\u044B \u049B\u0430\u0437\u0430\u049B\u0442\u0430\u0440
      \u0430\u0440\u0430\u0441\u044B\u043D\u0430\u043D \u049B\u0430\u0436\u044B\u043B\u044B\u049B\u049B\u0430
      \u0431\u0430\u0440\u0493\u0430\u043D\u0434\u0430\u0440 \u0442\u0456\u0437\u0456\u043C\u0456\u043D\u0434\u0435 
      \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u049B\u0430\u0436\u044B 221-\u0448\u0456
      \u0431\u043E\u043B\u044B\u043F,"
    englishText: 'In the 1905 registry of Kazakh pilgrims, Shakarim-haji appears
      under number 221 as:'
    duration: 7
  - russianText: "\xAB\u043A\u0438\u0440\u0433\u0438\u0437 \u0428\u0430\u043A\u0430\u0440\u0438\u043C
      \u041A\u0443\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0438\u043D \u0438\u0437
      \u0427\u0438\u043D\u0433\u0438\u0437\u0441\u043A\u043E\u0439 \u0432\u043E\u043B\u043E\u0441\u0442\u0438
      \u0421\u0435\u043C\u0438\u043F\u0430\u043B\u0430\u0442\u0438\u043D\u0441\u043A\u043E\u0433\u043E
      \u0443\u0435\u0437\u0434\u0430\xBB."
    kazakhText: "\xAB\u0421\u0435\u043C\u0435\u0439 \u0443\u0435\u0437\u0456 \u0428\u044B\u04A3\u0493\u044B\u0441
      \u0431\u043E\u043B\u044B\u0441\u0442\u044B\u0493\u044B\u043D\u044B\u04A3 \u049B\u044B\u0440\u0493\u044B\u0437\u044B
      \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0438\u043D\xBB
      \u0434\u0435\u043F \u0436\u0430\u0437\u044B\u043B\u0493\u0430\u043D."
    englishText: "\u201CKyrgyz Shakarim Qudaiberdin of the Chingis district of the
      Semipalatinsk region.\u201D"
    duration: 6
