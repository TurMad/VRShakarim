  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "3 \u041E\u043C\u0431\u044B \u041C\u043E\u0434\u0443\u043B\u044C 3"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0418\u0437 \u041E\u043C\u0441\u043A\u0430 \u0428\u0430\u043A\u0430\u0440\u0438\u043C
      \u041A\u0443\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0438\u0435\u0432 \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442\u0441\u044F
      \u043F\u043E\u0435\u0437\u0434\u043E\u043C"
    kazakhText: "\u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456\u04B1\u043B\u044B
      \u041E\u043C\u0431\u044B\u0434\u0430\u043D 1904 \u0436\u044B\u043B\u044B \u0430\u0448\u044B\u043B\u044B\u043F,"
    englishText: From Omsk, Shakarim Qudaiberdiuly boarded a train on the newly
    duration: 3
  - russianText: "\u043F\u043E \u043D\u043E\u0432\u043E\u0439 \u0422\u0440\u0430\u043D\u0441\u0441\u0438\u0431\u0438\u0440\u0441\u043A\u043E\u0439
      \u0436\u0435\u043B\u0435\u0437\u043D\u043E\u0439 \u0434\u043E\u0440\u043E\u0433\u0435,
      \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0439 \u0432 1904 \u0433\u043E\u0434\u0443"
    kazakhText: "\u04AF\u0448 \u0436\u0430\u0440\u044B\u043C \u043C\u044B\u04A3 \u0448\u0430\u049B\u044B\u0440\u044B\u043C\u0493\u0430
      \u0441\u043E\u0437\u044B\u043B\u0493\u0430\u043D \u0436\u0430\u04A3\u0430"
    englishText: opened Trans-Siberian Railway, inaugurated in 1904
    duration: 3
  - russianText: "\u0438 \u043F\u0440\u043E\u0442\u044F\u043D\u0443\u0432\u0448\u0435\u0439\u0441\u044F
      \u0431\u043E\u043B\u0435\u0435 \u0447\u0435\u043C \u043D\u0430 \u0442\u0440\u0438
      \u0441 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u043E\u0439 \u0442\u044B\u0441\u044F\u0447\u0438
      \u043A\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u043E\u0432."
    kazakhText: "\u0422\u0440\u0430\u043D\u0441\u0441\u0456\u0431\u0456\u0440 \u0442\u0435\u043C\u0456\u0440
      \u0436\u043E\u043B\u044B \u0430\u0440\u049B\u044B\u043B\u044B \u041C\u04D9\u0441\u043A\u0435\u0443\u0433\u0435
      \u0436\u04AF\u0440\u0435\u0442\u0456\u043D \u043F\u043E\u0439\u044B\u0437\u0493\u0430
      \u043E\u0442\u044B\u0440\u0430\u0434\u044B."
    englishText: and stretching more than three and a half thousand kilometers.
    duration: 4
  - russianText: "\u0414\u0432\u0430\u0436\u0434\u044B \u043F\u0435\u0440\u0435\u0441\u0430\u0436\u0438\u0432\u0430\u044F\u0441\u044C
      \u043D\u0430 \u0434\u0440\u0443\u0433\u0438\u0435 \u043F\u043E\u0435\u0437\u0434\u0430,"
    kazakhText: "\u0415\u043A\u0456 \u0440\u0435\u0442 \u043F\u043E\u0439\u044B\u0437
      \u0430\u0443\u044B\u0441\u0442\u044B\u0440\u044B\u043F,"
    englishText: Changing trains twice along the way,
    duration: 3
  - russianText: "\u0441\u043F\u0443\u0441\u0442\u044F \u043F\u044F\u0442\u044C \u0434\u043D\u0435\u0439
      \u043F\u0443\u0442\u0438 \u043E\u043D \u0432\u043C\u0435\u0441\u0442\u0435
      \u0441\u043E \u0441\u0432\u043E\u0438\u043C\u0438 \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430\u043C\u0438
      \u043F\u0440\u0438\u0431\u044B\u0432\u0430\u0435\u0442 \u0432 \u041C\u043E\u0441\u043A\u0432\u0443."
    kazakhText: "\u0431\u0435\u0441 \u043A\u04AF\u043D \u0456\u0448\u0456\u043D\u0434\u0435
      \u0441\u0430\u043F\u0430\u0440\u043B\u0430\u0441\u0442\u0430\u0440\u044B\u043C\u0435\u043D
      \u0431\u0456\u0440\u0433\u0435 \u041C\u04D9\u0441\u043A\u0435\u0443\u0433\u0435
      \u0436\u0435\u0442\u0435\u0434\u0456."
    englishText: he and his companions arrived in Moscow after five days of travel.
    duration: 4
