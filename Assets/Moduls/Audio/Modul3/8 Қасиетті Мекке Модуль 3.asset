--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85fca06edf66b4b45a90262da18341ba, type: 3}
  m_Name: "8 \u049A\u0430\u0441\u0438\u0435\u0442\u0442\u0456 \u041C\u0435\u043A\u043A\u0435
    \u041C\u043E\u0434\u0443\u043B\u044C 3"
  m_EditorClassIdentifier: Assembly-CSharp::SubtitleSequenceSO
  lines:
  - russianText: "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0430\u044F \u041C\u0435\u043A\u043A\u0430\u2026
      \u0428\u0430\u043A\u0430\u0440\u0438\u043C \u041A\u0443\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0438\u0435\u0432
      \u043F\u0438\u0441\u0430\u043B:"
    kazakhText: "\u049A\u0430\u0441\u0438\u0435\u0442\u0442\u0456 \u041C\u0435\u043A\u043A\u0435...
      \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u049A\u04B1\u0434\u0430\u0439\u0431\u0435\u0440\u0434\u0456\u04B1\u043B\u044B"
    englishText: "Holy Mecca\u2026 Shakarim Qudaiberdiuly wrote:"
    duration: 3
  - russianText: "\xAB\u041A\u043E\u0433\u0434\u0430 \u044F, \u0431\u0435\u0434\u043D\u044B\u0439
      \u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A, \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u043B
      \u0445\u0430\u0434\u0436 \u043D\u0430 \u0440\u0443\u0431\u0435\u0436\u0435
      1905\u20131906 \u0433\u043E\u0434\u043E\u0432, \u044F \u0443\u0432\u0438\u0434\u0435\u043B
      \u0442\u0430\u043A\u0438\u044E."
    kazakhText: "\xAB\u041C\u0435\u043D \u043F\u0430\u049B\u044B\u0440 1905 \u0436\u044B\u043B\u0434\u0430\u043D
      1906 \u0436\u044B\u043B\u0493\u0430 \u049B\u0430\u0440\u0430\u0439 \u049B\u0430\u0436\u044B\u0493\u0430
      \u0431\u0430\u0440\u0493\u0430\u043D\u0434\u0430 \u0442\u04D9\u043A\u0438\u04D9\u043D\u0456
      \u043A\u04E9\u0440\u0434\u0456\u043C."
    englishText: "\u201CWhen I, a humble wanderer, performed the Hajj at the turn
      of 1905\u20131906, I saw the takiya."
    duration: 7
  - russianText: "\u0414\u043E \u043C\u0435\u043D\u044F \u0442\u0443\u0434\u0430
      \u0443\u0436\u0435 \u0432\u043E\u0448\u043B\u0438 \u0434\u0440\u0443\u0433\u0438\u0435
      \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u043A\u0438."
    kazakhText: "\u041C\u0435\u043D\u0435\u043D \u0431\u04B1\u0440\u044B\u043D \u049B\u0430\u0436\u044B\u043B\u0430\u0440
      \u043A\u0456\u0440\u0456\u043F \u049B\u0430\u043B\u0493\u0430\u043D \u0435\u043A\u0435\u043D."
    englishText: Other pilgrims had already settled there before me.
    duration: 3
  - russianText: "\u041D\u0435 \u0436\u0435\u043B\u0430\u044F \u0438\u0445 \u0442\u0440\u0435\u0432\u043E\u0436\u0438\u0442\u044C,
      \u044F \u0441\u043D\u044F\u043B \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E\u0435
      \u0436\u0438\u043B\u044C\u0451\u2026\xBB"
    kazakhText: "\u041E\u043B\u0430\u0440\u0434\u044B \u0440\u0435\u043D\u0436\u0456\u0442\u043F\u0435\u0439,
      \u043F\u04D9\u0442\u0435\u0440 \u0430\u043B\u044B\u043F \u0442\u04AF\u0441\u0442\u0456\u043C\u2026\xBB
      \u0434\u0435\u0439\u0434\u0456."
    englishText: "Not wishing to disturb them, I rented separate lodging\u2026\u201D"
    duration: 3
  - russianText: "\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A
      \u0428\u0430\u043A\u0430\u0440\u0438\u043C\u0430 \u0421\u0430\u0431\u044B\u0440\u0436\u0430\u043D
      \u0413\u0430\u0431\u0431\u0430\u0441\u043E\u0432 \u043F\u0438\u0441\u0430\u043B
      \u0432 \u0436\u0443\u0440\u043D\u0430\u043B\u0435 \xAB\u0410\u0439\u049B\u0430\u043F\xBB:"
    kazakhText: "\u049A\u0430\u0436\u044B\u043D\u044B\u04A3 \u0437\u0430\u043C\u0430\u043D\u0434\u0430\u0441\u044B
      \u0421\u0430\u0431\u044B\u0440\u0436\u0430\u043D \u0492\u0430\u0431\u0431\u0430\u0441\u043E\u0432
      \xAB\u0410\u0439\u049B\u0430\u043F\xBB \u0436\u0443\u0440\u043D\u0430\u043B\u044B\u043D\u0434\u0430:"
    englishText: "Shakarim\u2019s contemporary, Sabyrzhan Gabbasov, wrote in the
      journal Aiqap:"
    duration: 5
  - russianText: "\xAB\u0421\u0435\u0433\u043E\u0434\u043D\u044F \u043F\u043E\u0447\u0442\u0435\u043D\u043D\u044B\u0439
      \u0438 \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u044B\u0439 \u0430\u043A\u0441\u0430\u043A\u0430\u043B,"
    kazakhText: "\xAB\u0411\u04B1\u043B \u043A\u04AF\u043D\u0434\u0435 \u043C\u0438\u043B\u043B\u0435\u0442\u0456\u043D\u0435
      \u049B\u0430\u043B\u0430\u043C\u043C\u0435\u043D\u0435\u043D \u049B\u044B\u0437\u043C\u0435\u0442
      \u049B\u044B\u043B\u044B\u043F \u0436\u0430\u0442\u049B\u0430\u043D"
    englishText: "\u201CToday the honorable and respected elder,"
    duration: 3
  - russianText: "\u0445\u0430\u0434\u0436\u0438 \u0428\u0430\u043A\u0430\u0440\u0438\u043C-\u0445\u0430\u0437\u0440\u0435\u0442,
      \u0441\u043B\u0443\u0436\u0438\u0442 \u0441\u0432\u043E\u0435\u043C\u0443 \u043D\u0430\u0440\u043E\u0434\u0443
      \u0441\u0432\u043E\u0438\u043C \u043F\u0435\u0440\u043E\u043C\u2026"
    kazakhText: "\u0444\u0430\u0437\u0438\u043B-\u04D9\u043B-\u043C\u04B1\u0445\u0442\u0430\u0440\u0430\u043C
      \u049B\u0430\u0434\u0456\u0440\u043B\u0456 \u0430\u049B\u0441\u0430\u049B\u0430\u043B
      \u04D9\u043B-\u0445\u0430\u0436\u044B \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C
      \u0445\u0430\u0437\u0440\u0435\u0442\u043B\u0435\u0440\u0456..."
    englishText: "Haji Shakarim-hazret, serves his people through his pen\u2026"
    duration: 5
  - russianText: "\u0414\u0430 \u0434\u0430\u0440\u0443\u0435\u0442 \u0412\u0441\u0435\u0432\u044B\u0448\u043D\u0438\u0439
      \u0434\u043E\u043B\u0433\u0443\u044E \u0438 \u0431\u043B\u0430\u0433\u043E\u0441\u043B\u043E\u0432\u0435\u043D\u043D\u0443\u044E
      \u0436\u0438\u0437\u043D\u044C \u0442\u0430\u043A\u0438\u043C \u0441\u0442\u0430\u0440\u0446\u0430\u043C,
      \u043A\u0430\u043A \u0428\u0430\u043A\u0430\u0440\u0438\u043C-\u0445\u0430\u0434\u0436\u0438,"
    kazakhText: "\u0410\u043B\u043B\u0430 \u0442\u0430\u0493\u0430\u043B\u0430 \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C
      \u049B\u0430\u0436\u044B \u0441\u0438\u044F\u049B\u0442\u044B \u0430\u049B\u0441\u0430\u049B\u0430\u043B\u0434\u0430\u0440\u044B\u043C\u044B\u0437\u0434\u044B\u04A3
      \u0493\u04B1\u043C\u044B\u0440\u044B\u043D\u0430 \u0431\u0435\u0440\u0435\u043A\u0435\u0442
      \u0431\u0435\u0440\u0456\u043F,"
    englishText: May the Almighty grant long and blessed years to elders such as
      Shakarim-haji,
    duration: 5
  - russianText: "\u0438 \u0434\u0430 \u043D\u0438\u0441\u043F\u043E\u0448\u043B\u0451\u0442
      \u043D\u0430\u0448\u0435\u0439 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u043E\u0439
      \u043C\u043E\u043B\u043E\u0434\u0451\u0436\u0438 \u0441\u0447\u0430\u0441\u0442\u044C\u0435
      \u0431\u044B\u0442\u044C \u043F\u043E\u0445\u043E\u0436\u0438\u043C\u0438 \u043D\u0430
      \u043D\u0435\u0433\u043E\xBB."
    kazakhText: "\u043E\u049B\u044B\u0493\u0430\u043D \u0436\u0430\u0441\u0442\u0430\u0440\u044B\u043C\u044B\u0437\u0493\u0430
      \u0428\u04D9\u043A\u04D9\u0440\u0456\u043C \u049B\u0430\u0436\u044B\u0434\u0430\u0439
      \u0431\u043E\u043B\u0443\u0493\u0430 \u043D\u04D9\u0441\u0456\u043F \u0435\u0442\u0441\u0456\u043D\xBB
      - \u0434\u0435\u043F \u0436\u0430\u0437\u0430\u0434\u044B."
    englishText: "and may our educated youth be granted the fortune to follow in
      his path.\u201D"
    duration: 5
